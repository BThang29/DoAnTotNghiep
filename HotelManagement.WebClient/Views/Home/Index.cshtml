              <line fill="none" stroke="#111111" stroke-width="3" stroke-miterlimit="10" x1="0" y1="12.9" x2="34"
                y2="12.9"></line>
              <polyline fill="none" stroke="#111111" stroke-width="3" stroke-miterlimit="10"
                points="22.2,1.1 34,12.9 22.2,24.7   "></polyline>
            </g>
          </svg></span>
      </a>
    </div>
  </section>

