@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = null;
    var __path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var __isHome = __path == "/" || __path == "/home" || __path == "/home/index";
    var __bodyClass = (__isHome ? "tl-home" : "tl-inner") + (ViewData["BodyClass"] is string bodyClass && !string.IsNullOrWhiteSpace(bodyClass) ? " " + bodyClass : string.Empty);
    var __today = DateTime.Today.ToString("yyyy-MM-dd");

    string ActiveExact(params string[] paths)
    {
        foreach (var path in paths)
        {
            if (__path == path)
            {
                return " active";
            }
        }

        return string.Empty;
    }

    string ActivePrefix(params string[] paths)
    {
        foreach (var path in paths)
        {
            if (__path == path || __path.StartsWith(path + "/"))
            {
                return " active";
            }
        }

        return string.Empty;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Telly Hotel</title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
