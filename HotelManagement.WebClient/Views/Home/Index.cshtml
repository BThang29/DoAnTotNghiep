  <section id="intro">
    <div class="image-holder position-relative home-hero-slider" aria-label="Không gian Telly Hotel">
      <img src="/telly/images/banner-item1.jpg" alt="Hồ bơi nghỉ dưỡng tại Telly" class="img-fluid is-active">
      <img src="/telly/images/banner-item2.jpg" alt="Phòng nghỉ tiện nghi tại Telly" class="img-fluid">
      <img src="/telly/images/banner-item3.jpg" alt="Khu nghỉ dưỡng Telly về đêm" class="img-fluid">
      <img src="/telly/images/banner-item4.jpg" alt="Không gian thư giãn tại Telly" class="img-fluid">
    </div>
    <div class="container-lg">
      <div class="banner-content position-absolute">
        <span class="light text-uppercase">Khách sạn hiện đại tại trung tâm</span>
        <h1 class="banner-title light display-1 text-capitalize py-3 lh-sm">Tận hưởng kỳ nghỉ trọn vẹn tại Telly.
        </h1>
        <p class="light fs-5 pb-4">Không gian phòng tiện nghi, dịch vụ tận tâm và quy trình đặt phòng nhanh chóng cho chuyến công tác hoặc nghỉ dưỡng của bạn.</p>

        <a href="/Room/Rooms" class="btn btn-arrow btn-pill btn-medium btn-outline-light position-relative">
          <span>Xem phòng<svg version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 36.1 25.8"
              enable-background="new 0 0 36.1 25.8" xml:space="preserve">
