@{
    ViewData["Title"] = "User System";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/css/user-system.css" rel="stylesheet" asp-append-version="true" />

<div class="container-fluid user-system-shell">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-800">Tài khoản người dùng</h1>
            <p class="mb-0 text-muted">Đổi mật khẩu đăng nhập cho tài khoản quản trị đang hoạt động.</p>
        </div>
        <a class="btn btn-outline-secondary shadow-sm" asp-controller="Home" asp-action="Index">
            <i class="fas fa-arrow-left fa-sm mr-1"></i> Quay lại trang chính
        </a>
    </div>

    <div class="card shadow mb-4 user-system-hero">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-lg-8 mb-4 mb-lg-0">
                    <h2 class="h3 mb-3 text-white">Cập nhật mật khẩu để bảo vệ tài khoản quản trị.</h2>
                </div>
                
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card shadow user-system-panel">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <div class="small text-muted" id="userSystemStatusText">Sẵn sàng cập nhật.</div>
                </div>
                <div class="card-body">
                    <form id="userSystemForm" novalidate>
                        <div class="form-group">
                            <label for="userSystemOldPassword">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" id="userSystemOldPassword" placeholder="Nhập mật khẩu hiện tại">
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="userSystemNewPassword">Mật khẩu mới</label>
                                    <input type="password" class="form-control" id="userSystemNewPassword" placeholder="Tối thiểu 6 ký tự">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="userSystemConfirmPassword">Xác nhận mật khẩu mới</label>
                                    <input type="password" class="form-control" id="userSystemConfirmPassword" placeholder="Nhập lại mật khẩu mới">
                                </div>
                            </div>
                        </div>
                        <div class="user-system-strength mb-3" id="userSystemStrengthText"></div>
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                            <div class="small text-muted mb-3 mb-md-0" id="userSystemLastValidation">Chưa có thay đổi nào được gửi.</div>
                            <div>
                                <button type="button" class="btn btn-outline-secondary mr-2" id="userSystemResetButton">Làm mới</button>
                                <button type="submit" class="btn btn-primary" id="userSystemSubmitButton">
                                    <i class="fas fa-key fa-sm mr-1"></i> Cập nhật mật khẩu
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/custom/user-system/user-system.js" asp-append-version="true"></script>
}
