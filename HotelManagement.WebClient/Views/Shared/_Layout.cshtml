    <script>
        (function () {
            const languageButton = document.getElementById("languageDropdown");
            const languageItems = document.querySelectorAll("[data-lang]");
            const languages = {
                vi: { label: "VN", flag: "/images/vn-flag.jpg", alt: "Tiếng Việt" },
                en: { label: "EN", flag: "/images/flag.jpg", alt: "English" }
            };

            if (!languageButton || languageItems.length === 0) {
                return;
            }

            function setLanguage(lang) {
                const current = languages[lang] || languages.vi;
                const flag = languageButton.querySelector(".tb-lang-flag");
                const label = languageButton.querySelector("span");

                if (flag) {
                    flag.src = current.flag;
                    flag.alt = current.alt;
                }

                if (label) {
                    label.textContent = current.label;
                }

                languageItems.forEach(item => {
                    item.classList.toggle("active", item.dataset.lang === lang);
                });

                localStorage.setItem("telly-language", lang);
            }

            setLanguage(localStorage.getItem("telly-language") || "vi");

            languageItems.forEach(item => {
                item.addEventListener("click", event => {
                    event.preventDefault();
                    setLanguage(item.dataset.lang || "vi");
                });
            });
        })();
    </script>
    <script>
        (function () {
            const drawer = document.getElementById("bookingDrawer");
            const panel = drawer?.querySelector(".booking-drawer__panel");
            const openButtons = document.querySelectorAll("[data-booking-drawer-open]");
            const closeButtons = drawer?.querySelectorAll("[data-booking-drawer-close]") || [];
            let closeTimer = null;

            if (!drawer || !panel || openButtons.length === 0) {
                return;
            }

            function openDrawer(event) {
                event?.preventDefault();
                window.clearTimeout(closeTimer);
                drawer.hidden = false;
                document.body.classList.add("booking-drawer-open");
                window.requestAnimationFrame(() => {
                    drawer.classList.add("is-open");
                    panel.focus({ preventScroll: true });
                });
            }

            function closeDrawer(event) {
                event?.preventDefault();
                drawer.classList.remove("is-open");
                document.body.classList.remove("booking-drawer-open");
                closeTimer = window.setTimeout(() => {
                    drawer.hidden = true;
                }, 360);
            }

            openButtons.forEach(button => button.addEventListener("click", openDrawer));
            closeButtons.forEach(button => button.addEventListener("click", closeDrawer));
            document.addEventListener("keydown", event => {
                if (event.key === "Escape" && !drawer.hidden) {
                    closeDrawer(event);
                }
            });
        })();
    </script>
