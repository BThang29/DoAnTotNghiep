@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu | Telly Hotel</title>
    <link href="https://fonts.googleapis.com/css?family=Lora:400,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Cabin:400,500,600,700&display=swap" rel="stylesheet">
    <link href="~/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" type="text/css">
        <link rel="stylesheet" href="~/css/notification.css" type="text/css">
            <link rel="stylesheet" href="~/css/auth.css" type="text/css">
            </head>
            <body class="auth-page">
                <main class="auth-shell auth-shell--forgot">
                    <section class="auth-panel auth-panel--form">
                        <a class="auth-brand" href="/Home/Index">Telly Hotel</a>
                        <div class="auth-copy">
                            <span class="auth-kicker">Hỗ trợ tài khoản</span>
                            <h1>Khôi phục quyền truy cập</h1>
                            <p>Nhập email đã dùng khi đăng ký. Hệ thống sẽ tạo mật khẩu mới và gửi hướng dẫn để bạn đăng nhập lại nhanh hơn.</p>
                        </div>

                        <form id="forgotPasswordForm" class="auth-form" novalidate>
                            <div class="auth-field">
                                <label for="forgotPasswordEmail">Email</label>
                                <input id="forgotPasswordEmail" name="email" type="email" placeholder="email@example.com" required />
                            </div>
                            <button id="forgotPasswordSubmitButton" type="submit" class="auth-submit">Khôi phục mật khẩu</button>
                        </form>

                        <div class="auth-inline-note">
                            <div class="auth-inline-note__icon">
                                <i class="fa fa-envelope-open-o" aria-hidden="true"></i>
                            </div>
                            <div>
                                <strong>Phản hồi qua email</strong>
                                <p>Kiểm tra cả hộp thư chính và thư rác sau khi gửi yêu cầu.</p>
                            </div>
                        </div>

                        <p class="auth-switch">
                            Đã nhớ mật khẩu?
                            <a href="/Auth/Login">Quay lại đăng nhập</a>
                        </p>
                    </section>

                    <section class="auth-panel auth-panel--visual">
                        <div class="auth-visual__content">
                            <span class="auth-kicker">An toàn tài khoản</span>
                            <h2>Lấy lại truy cập để tiếp tục quản lý đặt phòng, thanh toán và lịch sử lưu trú.</h2>

                            <div class="auth-metric-grid">
                                <article class="auth-metric-card">
                                    <span>01</span>
                                    <strong>Xác minh bằng email</strong>
                                    <p>Sử dụng đúng địa chỉ email đã liên kết với tài khoản của bạn.</p>
                                </article>
                                <article class="auth-metric-card">
                                    <span>02</span>
                                    <strong>Nhận mật khẩu mới</strong>
                                    <p>Hệ thống tạo lại mật khẩu để bạn đăng nhập ngay khi cần.</p>
                                </article>
                            </div>

                            <ul class="auth-feature-list auth-feature-list--check">
                                <li>Giảm gián đoạn khi cần truy cập lại tài khoản.</li>
                                <li>Tiếp tục theo dõi giao dịch và lịch sử đặt phòng.</li>
                                <li>Trải nghiệm khôi phục đơn giản trên cả desktop và mobile.</li>
                            </ul>
                        </div>
                    </section>
                </main>

                <script src="~/custom/notification.js"></script>
                <script src="~/custom/auth/forgotpassword.js"></script>
            </body>
        </html>
