@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin</title>
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
          rel="stylesheet" />
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet" />
    <link href="~/css/notification.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/admin-redesign.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/custom/layout/sidebar-adminlte.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/custom/layout/messenger-widget.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
   
</head>

<body id="page-top">

    <!-- Page Wrapper -->
    <div id="wrapper">

        <!-- Sidebar -->
        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion" id="accordionSidebar">

            <!-- Sidebar - Brand + nut thu gon -->
            <div class="sidebar-brand-wrap d-flex align-items-center">
                <a class="sidebar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="sidebar-brand-icon">
                        <i class="fas fa-hotel"></i>
                    </div>
                    <div class="sidebar-brand-text mx-2">
                        <span class="brand-title">Telly</span>
                        <span class="brand-subtitle">Quản trị khách sạn</span>
                    </div>
                </a>
                <button class="sidebar-collapse-btn border-0" id="sidebarToggle" type="button" aria-label="Thu gọn menu"></button>
            </div>

            <!-- Divider -->
            <hr class="sidebar-divider my-0">

            <!-- Nav Item - Dashboard -->
            <li class="nav-item" id="nav-dashboard" hidden>
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-fw fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <!-- Divider -->
            <hr class="sidebar-divider" id="nav-divider-after-dashboard" hidden>

            <!-- Heading -->
            <div class="sidebar-heading" id="nav-heading-operations" hidden>
                Vận hành
            </div>

            <li class="nav-item" id="nav-room-service-group" hidden>
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseUtilities"
                   aria-expanded="true" aria-controls="collapseUtilities">
                    <i class="fas fa-fw fa-concierge-bell"></i>
                    <span>Phòng và dịch vụ</span>
                </a>
                <div id="collapseUtilities" class="collapse" aria-labelledby="headingUtilities"
                     data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner rounded">
                        <h6 class="collapse-header">Room APIs</h6>
                        <a class="collapse-item" id="nav-rooms" asp-controller="Room" asp-action="Rooms" hidden>Danh sách phòng</a>
                        <a class="collapse-item" id="nav-room-types" asp-controller="Room" asp-action="RoomTypes" hidden>Loại phòng</a>
                        <a class="collapse-item" id="nav-room-statuses" asp-controller="Room" asp-action="RoomStatuses" hidden>Trạng thái phòng</a>
                        <div class="collapse-divider"></div>
                        <h6 class="collapse-header">Service APIs</h6>
                        <a class="collapse-item" id="nav-services" asp-controller="Other" asp-action="Services" hidden>Dịch vụ</a>
                        <a class="collapse-item" id="nav-service-types" asp-controller="Other" asp-action="ServiceTypes" hidden>Loại dịch vụ</a>
                    </div>
                </div>
            </li>

            <li class="nav-item" id="nav-booking-payment-group" hidden>
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseTwo"
                   aria-expanded="true" aria-controls="collapseTwo">
                    <i class="fas fa-fw fa-money-check-alt"></i>
                    <span>Phòng và thanh toán</span>
                </a>
                <div id="collapseTwo" class="collapse" aria-labelledby="headingTwo" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner rounded">
                        <h6 class="collapse-header">Booking APIs</h6>
                        <a class="collapse-item" id="nav-booking-room" asp-controller="BookingRoom" asp-action="BookingRoom" hidden>Đặt phòng</a>
                        <a class="collapse-item" id="nav-check-available-room" asp-controller="BookingRoom" asp-action="CheckAvailableRoom" hidden>Phòng trống</a>
                        <a class="collapse-item" id="nav-deposit" asp-controller="BookingRoom" asp-action="Deposit" hidden>Tiền cọc</a>
                        <a class="collapse-item" id="nav-invoices" asp-controller="Invoice" asp-action="Invoices" hidden>Hóa đơn</a>
                        <a class="collapse-item" id="nav-payments" asp-controller="Payment" asp-action="Payments" hidden>Thanh toán</a>
                        <a class="collapse-item" id="nav-payment-qr" asp-controller="Payment" asp-action="PaymentQr" hidden>QR thanh toán</a>
                    </div>
                </div>
            </li>

            <!-- Divider -->
            <hr class="sidebar-divider" id="nav-divider-management" hidden>

            <!-- Heading -->
            <div class="sidebar-heading" id="nav-heading-management" hidden>
                Quản lý
            </div>

            <li class="nav-item" id="nav-customer-group" hidden>
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseCustomer"
                   aria-expanded="true" aria-controls="collapseCustomer">
                    <i class="fas fa-fw fa-user-friends"></i>
                    <span>Khách hàng</span>
                </a>
                <div id="collapseCustomer" class="collapse" aria-labelledby="headingCustomer" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner rounded">
                        <h6 class="collapse-header">Customer APIs</h6>
                        <a class="collapse-item" id="nav-customer-list" asp-controller="Customer" asp-action="Customers" hidden>Danh sách khách hàng</a>
                        <a class="collapse-item" id="nav-customer-reviews" asp-controller="Review" asp-action="Reviews" hidden>Review khách hàng</a>
                    </div>
                </div>
            </li>

            <li class="nav-item" id="nav-staff-group" hidden>
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapseStaff"
                   aria-expanded="true" aria-controls="collapseStaff">
                    <i class="fas fa-fw fa-users-cog"></i>
                    <span>Nhân sự và quyền</span>
                </a>
                <div id="collapseStaff" class="collapse" aria-labelledby="headingStaff" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner rounded">
                        <h6 class="collapse-header">Staff APIs</h6>
                        <a class="collapse-item" id="nav-employees" asp-controller="Employee" asp-action="Employees" hidden>Nhân viên</a>
                        <a class="collapse-item" id="nav-roles" asp-controller="Role" asp-action="Roles" hidden>Vai trò</a>
                    </div>
                </div>
            </li>

            <hr class="sidebar-divider">

            <div class="sidebar-heading">
                Tài khoản
            </div>

            <li class="nav-item">
                <a class="nav-link" asp-controller="UserSystem" asp-action="Information">
                    <i class="fas fa-fw fa-user"></i>
                    <span>Hồ sơ</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" asp-controller="UserSystem" asp-action="ChangePassword">
                    <i class="fas fa-fw fa-key"></i>
                    <span>Mật khẩu</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="#" id="sidebarLogoutLink" data-toggle="modal" data-target="#logoutModal">
                    <i class="fas fa-fw fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </li>

            <!-- Divider -->
            <hr class="sidebar-divider d-none d-md-block" id="nav-divider-bottom" hidden>

        </ul>
        <!-- End of Sidebar -->
        <!-- Content Wrapper -->
        <div id="content-wrapper" class="d-flex flex-column">

            <!-- Main Content -->
            <div id="content">
                <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <ul class="navbar-nav ml-auto">

                        <!-- Messenger - tin nhan tu van -->
                        <li class="nav-item dropdown no-arrow mx-1" id="messengerNavItem">
                            <a class="nav-link dropdown-toggle" href="#" id="messengerToggle" role="button"
                               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fab fa-facebook-messenger fa-fw"></i>
                                <span class="badge badge-danger badge-counter messenger-badge-hidden" id="messengerBadge">0</span>
                            </a>
                            <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in"
                                 aria-labelledby="messengerToggle" id="messengerDropdown">
                                <h6 class="dropdown-header">Tin nhắn tư vấn</h6>
                                <div id="messengerThreadList">
                                    <div class="messenger-empty">Đang tải...</div>
                                </div>
                            </div>
                        </li>

                        <li class="nav-item dropdown no-arrow d-sm-none">
                            <a class="nav-link dropdown-toggle" href="#" id="searchDropdown" role="button"
                               data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-search fa-fw"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right p-3 shadow animated--grow-in"
                                 aria-labelledby="searchDropdown">
                                <form class="form-inline mr-auto w-100 navbar-search">
                                    <div class="input-group">
                                        <input type="text" class="form-control bg-light border-0 small"
                                               placeholder="Search for..." aria-label="Search"
                                               aria-describedby="basic-addon2">
                                        <div class="input-group-append">
                                            <button class="btn btn-primary" type="button">
                                                <i class="fas fa-search fa-sm"></i>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </li>
                        <div class="topbar-divider d-none d-sm-block"></div>

                        <li class="nav-item no-arrow">
                            <div class="nav-link d-flex align-items-center">
                                <span id="userLogin" class="mr-2 d-none d-lg-inline text-gray-600 small"></span>
                                <img class="img-profile rounded-circle" src="~/images/undraw_profile.svg" />
                            </div>
                        </li>
                    </ul>
                </nav>

                @RenderBody()
            </div>
            <!-- End of Main Content -->
            <!-- Footer -->
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>Đồ án quản lý khách sạn 2026</span>
                    </div>
                </div>
            </footer>
            <!-- End of Footer -->

        </div>
        <!-- End of Content Wrapper -->

    </div>
    <!-- End of Page Wrapper -->
    <!-- Messenger popups (goc duoi phai) -->
    <div id="messengerPopups" class="messenger-popups"></div>

    <!-- Scroll to Top Button-->
    <a class="scroll-to-top rounded" href="#page-top">
        <i class="fas fa-angle-up"></i>
    </a>

    <!-- Logout Modal-->
    <div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
         aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="button" id="logoutButton">Logout</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap core JavaScript-->
    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="~/js/sb-admin-2.min.js" asp-append-version="true"></script>

    <!-- Page level plugins -->
    <script src="~/vendor/chart.js/chart.min.js" asp-append-version="true"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        window.appConfig = {
            apiBaseUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5010"))
        };
    </script>
    <script src="~/custom/notification.js" asp-append-version="true"></script>
    <script src="~/custom/api-admin.js" asp-append-version="true"></script>
    <script src="~/custom/auth/logout.js" asp-append-version="true"></script>
    <script src="~/custom/layout/navbar-privileges.js" asp-append-version="true"></script>
    <script src="~/custom/layout/sidebar-active.js" asp-append-version="true"></script>
    <script src="~/custom/layout/messenger-widget.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
