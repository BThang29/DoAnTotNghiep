
@{
    ViewData["Title"] = "Liên hệ";
}

<section class="tl-contact-page">
    <div class="tl-contact-hero">
        <div class="container">
            <span class="tl-contact-kicker">Liên hệ Telly Hotel</span>
            <h1>Chúng tôi luôn sẵn sàng hỗ trợ kỳ nghỉ của bạn</h1>
            <p>Gửi yêu cầu tư vấn, đặt phòng hoặc phản hồi dịch vụ. Đội ngũ lễ tân sẽ phản hồi trong thời gian sớm nhất.</p>
        </div>
    </div>

    <div class="container tl-contact-wrap">
        <div class="tl-contact-grid">
            <aside class="tl-contact-card tl-contact-info-card">
                <span class="tl-contact-card__eyebrow">Thông tin khách sạn</span>
                <h2>Telly Hotel</h2>
                <p class="tl-contact-card__intro">Không gian lưu trú yên tĩnh tại trung tâm Huế, thuận tiện cho công tác và nghỉ dưỡng.</p>

                <div class="tl-contact-list">
                    <div class="tl-contact-item">
                        <span class="tl-contact-icon"><i class="fa fa-map-marker"></i></span>
                        <div>
                            <strong>Địa chỉ</strong>
                            <span>Số 1 đường Hùng Vương</span>
                        </div>
                    </div>
                    <div class="tl-contact-item">
                        <span class="tl-contact-icon"><i class="fa fa-phone"></i></span>
                        <div>
                            <strong>Điện thoại</strong>
                            <a href="tel:0795596255">079 559 6255</a>
                        </div>
                    </div>
                    <div class="tl-contact-item">
                        <span class="tl-contact-icon"><i class="fa fa-envelope"></i></span>
                        <div>
                            <strong>Email</strong>
                            <a href="mailto:hunga4vjp@gmail.com">thang7789o@gmail.com/a>
                        </div>
                    </div>
                    <div class="tl-contact-item">
                        <span class="tl-contact-icon"><i class="fa fa-clock-o"></i></span>
                        <div>
                            <strong>Giờ hỗ trợ</strong>
                            <span>24/7 cho đặt phòng và khách lưu trú</span>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="tl-contact-card tl-contact-form-card">
                <span class="tl-contact-card__eyebrow">Gửi tin nhắn</span>
                <h2>Bạn cần hỗ trợ?</h2>
                <form action="#" class="tl-contact-modern-form">
                    <div class="tl-contact-form-row">
                        <label>
                            <span>Họ và tên</span>
                            <input type="text" placeholder="Nhập tên của bạn">
                        </label>
                        <label>
                            <span>Email</span>
                            <input type="email" placeholder="email@example.com">
                        </label>
                    </div>
                    <label>
                        <span>Nội dung</span>
                        <textarea placeholder="Bạn muốn đặt phòng, tư vấn dịch vụ hay cần hỗ trợ thêm?"></textarea>
                    </label>
                    <button type="submit" class="tl-contact-submit">
                        <span>Gửi yêu cầu</span>
                        <i class="fa fa-paper-plane"></i>
                    </button>
                </form>
            </div>
        </div>

        <section class="tl-contact-map-card" aria-label="Bản đồ Telly Hotel">
            <div class="tl-contact-map-copy">
                <span>Vị trí</span>
                <h2>Tọa lạc ngay tại trung tâm Quận 1</h2>
                <p>Gần phố đi bộ Nguyễn Huệ, bến Bạch Đằng và các điểm tham quan nổi bật.</p>
            </div>
            <div class="tl-contact-map">
                <iframe
                    src="https://maps.google.com/maps?q=So%201%20duong%20Hung%20Vuong%2C%20Tp.%20Hue&z=16&output=embed"
                    title="Số 1 đường Hùng Vương, Tp.Huế" loading="lazy" allowfullscreen=""></iframe>
            </div>
        </section>
    </div>
</section>
