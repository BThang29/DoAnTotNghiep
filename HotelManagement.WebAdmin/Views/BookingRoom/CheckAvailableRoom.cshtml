@{
    ViewData["Title"] = "CheckAvailableRoom";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid check-room-workspace">
    <div class="check-room-hero">
        <div>
            <div class="check-room-kicker">Availability console</div>
            <h1>Kiểm tra phòng trống</h1>
            <p>Chọn khoảng lưu trú và loại phòng để xem ngay các phòng có thể nhận booking.</p>
        </div>
        <a href="/BookingRoom/CreateBookingRoom" class="btn check-room-create-btn">
            <i class="fas fa-plus fa-sm"></i>
            Tạo đặt phòng
        </a>
    </div>

    <section class="check-room-search-panel">
        <div class="check-room-filter-grid">
            <div class="form-group">
                <label for="checkAvailableRoomDateStart">Ngày nhận phòng</label>
                <input type="date" class="form-control" id="checkAvailableRoomDateStart">
            </div>

            <div class="form-group">
                <label for="checkAvailableRoomDateEnd">Ngày trả phòng</label>
                <input type="date" class="form-control" id="checkAvailableRoomDateEnd">
            </div>

            <div class="form-group">
                <label for="checkAvailableRoomTypeId">Loại phòng</label>
                <select class="form-control" id="checkAvailableRoomTypeId">
                    <option value="">Tất cả loại phòng</option>
                </select>
            </div>

            <button type="button" class="btn btn-primary" id="checkAvailableRoomSearchButton">
                <i class="fas fa-search fa-sm"></i>
                Kiểm tra
            </button>
        </div>
    </section>

    <section class="check-room-summary">
        <div class="check-room-summary-item">
            <span>Khoảng thời gian</span>
            <strong id="checkAvailableRoomSummaryDate">-</strong>
        </div>
        <div class="check-room-summary-item">
            <span>Loại phòng</span>
            <strong id="checkAvailableRoomSummaryType">Tất cả</strong>
        </div>
        <div class="check-room-summary-item is-count">
            <span>Số phòng trống</span>
            <strong id="checkAvailableRoomSummaryCount">0</strong>
        </div>
    </section>

    <section class="check-room-results-panel">
        <div class="check-room-results-head">
            <div>
                <div class="check-room-kicker">Kết quả</div>
                <h2>Danh sách phòng trống</h2>
                <p id="checkAvailableRoomHelpText">Chưa có dữ liệu. Hãy chọn thời gian và bấm kiểm tra.</p>
            </div>
            <span id="checkAvailableRoomResultBadge">0 phòng</span>
        </div>

        <div class="row check-room-result-grid" id="checkAvailableRoomList">
            <div class="col-12">
                <div class="check-room-empty-state">
                    <div class="check-room-empty-icon">
                        <i class="fas fa-bed"></i>
                    </div>
                    <div class="font-weight-bold text-gray-800 mb-2">Chưa có dữ liệu tra cứu</div>
                    <div class="text-muted small">Kết quả phòng trống sẽ hiển thị ở đây sau khi bạn chọn bộ lọc.</div>
                </div>
            </div>
        </div>

        <div class="check-room-pagination" id="checkAvailableRoomPaginationWrapper" hidden>
            <nav aria-label="Phân trang phòng trống">
                <ul class="pagination pagination-sm mb-0" id="checkAvailableRoomPagination"></ul>
            </nav>
        </div>
    </section>
</div>


@section Styles {
    <link href="~/custom/booking-room/check-available-room.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="~/custom/booking-room/check-available-room.js" asp-append-version="true"></script>
}
