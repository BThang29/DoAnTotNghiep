
@{
    ViewData["Title"] = "Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/customer.css" rel="stylesheet" asp-append-version="true" />
@section Styles {
    <link href="~/custom/customer/reviews.css" rel="stylesheet" asp-append-version="true" />
}

<div class="container-fluid customer-page admin-redesign reviews-page review-workspace">
    <section class="review-hero">
        <div>
            <div class="review-kicker">Room feedback</div>
            <h1>Review theo phòng</h1>
            <p>Chọn phòng, lọc nhanh và xem toàn bộ phản hồi khách hàng trong một màn hình gọn hơn.</p>
        </div>
        <a class="btn btn-outline-secondary review-back-button" asp-controller="Room" asp-action="Rooms">
            <i class="fas fa-arrow-left fa-sm mr-1"></i> Quay lại phòng
        </a>
    </section>

    <div class="review-layout">
        <aside class="review-panel review-room-panel">
            <div class="review-panel-header">
                <div>
                    <div class="review-kicker">Danh sách</div>
                    <h2>Phòng</h2>
                </div>
                <div class="review-summary-pill" id="reviewCustomerSummary">Đang tải...</div>
            </div>

            <div class="review-filter-card">
                <div class="review-filter-grid">
                    <div class="review-field review-keyword-field">
                        <label for="reviewCustomerKeyword">Từ khóa</label>
                        <input type="text" class="form-control" id="reviewCustomerKeyword" placeholder="Tên phòng...">
                    </div>
                    <div class="review-field">
                        <label for="reviewCustomerTypeFilter">Loại phòng</label>
                        <select class="form-control" id="reviewCustomerTypeFilter">
                            <option value="">Tất cả</option>
                        </select>
                    </div>
                    <div class="review-field">
                        <label for="reviewCustomerItemsPerPage">Hiển thị</label>
                        <select class="form-control" id="reviewCustomerItemsPerPage">
                            <option value="5">5 phòng</option>
                            <option value="8">8 phòng</option>
                            <option value="12">12 phòng</option>
                            <option value="20">20 phòng</option>
                        </select>
                    </div>
                </div>

                <div class="review-filter-actions">
                    <div class="review-filter-buttons">
                        <button type="button" class="btn btn-primary btn-sm" id="reviewCustomerSearchButton">
                            <i class="fas fa-search fa-sm mr-1"></i> Tìm
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="reviewCustomerResetButton">Làm mới</button>
                    </div>
                    <div class="review-pagination-info" id="reviewCustomerPaginationInfo">Chưa có dữ liệu.</div>
                </div>
            </div>

            <div class="customer-list-stack review-room-list" id="reviewCustomerList">
                <div class="text-center text-muted py-5">Đang tải danh sách phòng...</div>
            </div>

            <nav aria-label="Review room pagination" class="review-pagination-nav">
                <ul class="pagination pagination-sm mb-0 justify-content-end" id="reviewCustomerPagination"></ul>
            </nav>
        </aside>

        <section class="review-panel review-detail-panel">
            <div class="review-panel-header review-detail-header">
                <div>
                    <div class="review-kicker">Chi tiết</div>
                    <h2>Lịch sử review</h2>
                </div>
                <div class="review-summary-pill muted" id="reviewHistorySummary">Chưa chọn phòng.</div>
            </div>

            <div class="customer-selection-box review-selected-box">
                <div>
                    <div class="customer-selection-title">Phòng đang chọn</div>
                    <div class="customer-selection-value" id="reviewSelectedCustomerName">Chưa chọn phòng</div>
                    <div class="small text-muted mt-2" id="reviewSelectedCustomerMeta">Chọn một phòng từ danh sách bên trái để tải toàn bộ review của phòng đó.</div>
                </div>
                <div class="review-selected-icon">
                    <i class="fas fa-comments"></i>
                </div>
            </div>

            <div class="review-stat-grid">
                <div class="customer-mini-stat">
                    <div class="customer-mini-stat-label">Tổng review</div>
                    <div class="customer-mini-stat-value" id="reviewCount">0</div>
                </div>
                <div class="customer-mini-stat">
                    <div class="customer-mini-stat-label">Điểm trung bình</div>
                    <div class="customer-mini-stat-value" id="reviewAverageRating">0.0</div>
                </div>
                <div class="customer-mini-stat">
                    <div class="customer-mini-stat-label">Review mới nhất</div>
                    <div class="customer-mini-stat-value customer-mini-stat-date" id="reviewLatestDate">-</div>
                </div>
            </div>

            <div class="review-history-stack" id="reviewHistoryList">
                <div class="text-center text-muted py-5">Chưa có dữ liệu review để hiển thị.</div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/custom/customer/reviews.js" asp-append-version="true"></script>
    <script src="~/custom/customer/review-history.js" asp-append-version="true"></script>
}
