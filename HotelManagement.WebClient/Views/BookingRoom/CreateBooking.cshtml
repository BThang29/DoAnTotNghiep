
@{
    ViewData["Title"] = "Đặt phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<main class="booking-room-shell">
    <div class="container">
        <section class="booking-room-hero">
            <span class="booking-room-kicker">Booking Room</span>
            <h1>Hoàn tất thông tin đặt phòng</h1>
            <p>
                Xác nhận phòng bạn đã chọn, điền thông tin lưu trú và gửi yêu cầu đặt phòng ngay trên một màn hình duy nhất.
            </p>
        </section>

        <div class="booking-room-grid">
            <section class="booking-room-card booking-room-form-card">
                <h2 class="booking-room-section-title">Thông tin khách đặt</h2>
                <p class="booking-room-section-copy">
                    Nếu bạn đã đăng nhập, có thể dùng nhanh dữ liệu tài khoản. Nếu chưa, vẫn có thể nhập thủ công và gửi yêu cầu đặt phòng.
                </p>

                <div class="booking-room-auth-actions">
                    <button type="button" class="booking-room-secondary" id="bookingRoomUseSessionButton" style="display:none;">Sử dụng dữ liệu đăng nhập</button>
                    <a href="/Auth/Login" class="booking-room-secondary" id="bookingRoomLoginLink">Đăng nhập</a>
                </div>
                <div class="booking-room-auth-note" id="bookingRoomAuthNote">Đang kiểm tra phiên đăng nhập...</div>

                <form id="bookingRoomForm">
                    <div class="booking-room-fields">
                        <div class="booking-room-field">
                            <label for="bookingRoomFullName">Họ và tên</label>
                            <input type="text" id="bookingRoomFullName" placeholder="Nguyen Van A">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomIdentify">CCCD / Hộ chiếu</label>
                            <input type="text" id="bookingRoomIdentify" placeholder="0123456789">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomPhone">Số điện thoại</label>
                            <input type="text" id="bookingRoomPhone" placeholder="0901234567">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomMail">Email</label>
                            <input type="email" id="bookingRoomMail" placeholder="email@example.com">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomDob">Ngày sinh</label>
                            <input type="date" id="bookingRoomDob">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomDeposit">Tiền cọc</label>
                            <input type="number" id="bookingRoomDeposit" min="0" step="1000" placeholder="0">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomDateStart">Ngày nhận phòng</label>
                            <input type="date" id="bookingRoomDateStart" min="@today">
                        </div>
                        <div class="booking-room-field">
                            <label for="bookingRoomDateEnd">Ngày trả phòng</label>
                            <input type="date" id="bookingRoomDateEnd" min="@today">
                        </div>
                        <div class="booking-room-field booking-room-field--full">
                            <label for="bookingRoomVoucherId">Voucher ID</label>
                            <input type="number" id="bookingRoomVoucherId" min="1" step="1" placeholder="Tùy chọn">
                        </div>
                    </div>

                    <div class="booking-room-actions">
                        <button type="submit" class="booking-room-primary" id="bookingRoomSubmitButton">Gửi yêu cầu đặt phòng</button>
                        <a href="/BookingRoom/AvailableRooms" class="booking-room-secondary">Quay lại danh sách phòng</a>
                    </div>
                    <div class="booking-room-state" id="bookingRoomState"></div>
                </form>
            </section>

            <aside class="booking-room-card booking-room-summary-card">
                <img id="bookingRoomImage" src="/images/room/room-1.jpg" alt="Xem trước phòng">
                <h3 class="booking-room-summary-name" id="bookingRoomSummaryName">Đang tải thông tin phòng...</h3>
                <div class="booking-room-summary-price" id="bookingRoomSummaryPrice">Liên hệ<span>/đêm</span></div>
                <div class="booking-room-summary-list">
                    <div class="booking-room-summary-item">
                        <span>Mã phòng</span>
                        <strong id="bookingRoomSummaryId">#--</strong>
                    </div>
                    <div class="booking-room-summary-item">
                        <span>Loại phòng</span>
                        <strong id="bookingRoomSummaryType">--</strong>
                    </div>
                    <div class="booking-room-summary-item">
                        <span>Ngày lưu trú</span>
                        <strong id="bookingRoomSummaryDates">--</strong>
                    </div>
                    <div class="booking-room-summary-item">
                        <span>Trạng thái</span>
                        <strong id="bookingRoomSummaryStatus">--</strong>
                    </div>
                </div>
                <p id="bookingRoomSummaryDescription" class="booking-room-section-copy" style="margin-bottom:0;">
                    Màn hình này sẽ dùng dữ liệu phòng từ API để bạn xác nhận trước khi gửi yêu cầu đặt phòng.
                </p>
            </aside>
        </div>
    </div>
</main>

