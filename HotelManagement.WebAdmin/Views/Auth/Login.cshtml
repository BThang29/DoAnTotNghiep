@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Đăng nhập quản trị</title>

    <!-- Custom fonts for this template-->
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
          rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet" />
    <link href="~/css/notification.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />
</head>

<body class="admin-auth-page">

    <main class="auth-shell">
        <section class="auth-card auth-card-login">
            <div class="auth-visual">
                <div class="auth-brand">
                    <div class="auth-brand-icon">
                        <i class="fas fa-hotel"></i>
                    </div>
                    <div>
                        <span class="auth-brand-name">Telly Admin</span>
                        <span class="auth-brand-caption">Hotel Management System</span>
                    </div>
                </div>

                <div class="auth-visual-content">
                    <span class="auth-eyebrow">Control Center</span>
                    <h1>Quản lý vận hành khách sạn trong một màn hình.</h1>
                    <p>Theo dõi đặt phòng, hóa đơn, khách hàng và nhân sự với quyền truy cập bảo mật.</p>
                </div>

                <div class="auth-visual-stats">
                    <div>
                        <strong>24/7</strong>
                        <span>Vận hành</span>
                    </div>
                    <div>
                        <strong>Realtime</strong>
                        <span>Dữ liệu</span>
                    </div>
                </div>
            </div>

            <div class="auth-panel">
                <div class="auth-form-wrap">
                    <div class="auth-heading">
                        <span class="auth-kicker">Đăng nhập</span>
                        <h2>Chào mừng quay lại</h2>
                        <p>Nhập tài khoản quản trị để tiếp tục vào hệ thống.</p>
                    </div>

                    <form class="auth-form user" id="loginForm">
                        <div class="auth-field">
                            <label for="username">Tên đăng nhập</label>
                            <div class="auth-input-group">
                                <i class="fas fa-user-shield"></i>
                                <input type="text" class="form-control form-control-user"
                                       id="username" placeholder="duynam" autocomplete="username">
                            </div>
                        </div>

                        <div class="auth-field">
                            <label for="password">Mật khẩu</label>
                            <div class="auth-input-group">
                                <i class="fas fa-lock"></i>
                                <input type="password" class="form-control form-control-user"
                                       id="password" placeholder="Nhập mật khẩu" autocomplete="current-password">
                            </div>
                        </div>

                        <div class="auth-options">
                            <div class="custom-control custom-checkbox small">
                                <input type="checkbox" class="custom-control-input" id="rememberMe">
                                <label class="custom-control-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                            </div>
                            <a href="#" class="auth-link">Quên mật khẩu?</a>
                        </div>

                        <button type="submit" id="loginButton" class="btn auth-submit btn-block">
                            Đăng nhập
                        </button>
                    </form>

                    <p class="auth-switch">
                        Chưa có tài khoản?
                        <a href="/Auth/Register">Tạo tài khoản mới</a>
                    </p>
                </div>
            </div>
        </section>
    </main>

    <!-- Bootstrap core JavaScript-->
    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- Core plugin JavaScript-->
    <script src="~/vendor/jquery-easing/jquery.easing.min.js"></script>
    <!-- Custom scripts for all pages-->
    <script src="~/js/sb-admin-2.min.js" asp-append-version="true"></script>
    <script>
        window.appConfig = {
            apiBaseUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5010"))
        };
    </script>
    <script src="~/custom/api-admin.js" asp-append-version="true"></script>
    <script src="~/custom/notification.js" asp-append-version="true"></script>
    <script src="~/custom/auth/login.js" asp-append-version="true"></script>
</body>

</html>
