@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu | Telly Hotel</title>
    <link href="https://fonts.googleapis.com/css?family=Lora:400,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Cabin:400,500,600,700&display=swap" rel="stylesheet">
    <link href="~/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" type="text/css">
    <link rel="stylesheet" href="~/css/notification.css" type="text/css">
    
    <style>
        /* CSS tùy chỉnh bố cục Card trung tâm với tone màu CAM - TRẮNG */
        body {
            font-family: 'Cabin', sans-serif;
            /* Đổi nền thành gradient trắng phối cam siêu nhạt */
            background: linear-gradient(135deg, #fff3e0 0%, #fdfdfd 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .auth-card {
            background-color: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            max-width: 900px;
            width: 100%;
            display: flex;
            flex-wrap: wrap;
        }
        .auth-visual {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.25), rgba(15, 23, 42, 0.72)), url('/telly/images/single-image2.jpg') center/cover no-repeat;
            background-color: #1a2d3d;
            position: relative;
            color: #ffffff;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 500px;
            min-width: 300px;
        }
        .auth-visual::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(17, 34, 51, 0.7); /* Lớp phủ làm tối ảnh */
            z-index: 1;
        }
        .auth-visual-content {
            position: relative;
            z-index: 2;
        }
        .auth-form-section {
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        /* Chỉnh viền khi click vào input sang màu cam */
        .form-control {
            border-radius: 8px;
            padding: 12px 15px;
            font-size: 14px;
        }
        .form-control:focus {
            border-color: #ff7a00;
            box-shadow: 0 0 0 0.2rem rgba(255, 122, 0, 0.25);
        }

        /* Đổi màu nút sang Cam */
        .btn-primary {
            background-color: #ff7a00;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 600;
            color: #ffffff;
        }
        .btn-primary:hover, .btn-primary:focus, .btn-primary:active {
            background-color: #e66e00 !important;
            box-shadow: none !important;
        }

        /* Lớp CSS cho các text/link màu cam */
        .text-accent {
            color: #ff7a00 !important;
        }
        a.text-accent:hover {
            color: #e66e00 !important;
            text-decoration: underline;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 15px;
            backdrop-filter: blur(5px);
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center">
        <div class="auth-card row mx-0">
            
            <div class="col-md-6 auth-visual">
                <div class="auth-visual-content">
                    <div class="d-flex align-items-center mb-5">
                        <div class="bg-white text-dark rounded d-flex align-items-center justify-content-center mr-3" style="width: 40px; height: 40px;">
                            <i class="fa fa-building-o fa-lg"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 font-weight-bold">Telly Admin</h5>
                            <small style="letter-spacing: 1px; font-size: 10px; opacity: 0.8;">HOTEL MANAGEMENT SYSTEM</small>
                        </div>
                    </div>

                    <p class="text-uppercase font-weight-bold mb-2 text-accent" style="font-size: 12px;">Hỗ trợ tài khoản</p>
                    <h2 class="font-weight-bold mb-3" style="font-family: 'Lora', serif; font-size: 28px;">Khôi phục quyền truy cập màn hình.</h2>
                    <p style="opacity: 0.8; font-size: 14px; line-height: 1.6;">Nhập email đã dùng khi đăng ký. Hệ thống sẽ tạo mật khẩu mới và gửi hướng dẫn để bạn đăng nhập lại nhanh hơn.</p>
                </div>

                <div class="auth-visual-content row mt-5">
                    <div class="col-6">
                        <div class="stat-box">
                            <h5 class="font-weight-bold mb-1 text-accent">01</h5>
                            <small>Xác minh bằng email</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-box">
                            <h5 class="font-weight-bold mb-1 text-accent">02</h5>
                            <small>Nhận mật khẩu mới</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 auth-form-section">
                <p class="text-uppercase font-weight-bold mb-1 text-accent" style="font-size: 12px;">KHÔI PHỤC</p>
                <h3 class="font-weight-bold mb-4" style="color: #112233;">Quên mật khẩu</h3>
                <p class="text-muted mb-4" style="font-size: 14px;">Nhập email tài khoản quản trị để nhận lại mật khẩu.</p>

                <form id="forgotPasswordForm" novalidate>
                    <div class="form-group mb-4">
                        <label for="forgotPasswordEmail" class="font-weight-bold text-dark" style="font-size: 13px;">Địa chỉ Email</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white"><i class="fa fa-envelope-o text-muted"></i></span>
                            </div>
                            <input id="forgotPasswordEmail" name="email" type="email" class="form-control border-left-0" style="padding-left: 0;" placeholder="admin@example.com" required />
                        </div>
                    </div>

                    <button id="forgotPasswordSubmitButton" type="submit" class="btn btn-primary btn-block shadow-sm">Khôi phục mật khẩu</button>
                </form>

                <div class="text-center mt-5">
                    <p class="text-muted mb-0" style="font-size: 14px;">
                        Chưa có tài khoản? <a href="/Auth/Register" class="font-weight-bold text-accent">Tạo tài khoản mới</a>
                    </p>
                    <p class="text-muted mt-2" style="font-size: 14px;">
                        Đã nhớ mật khẩu? <a href="/Auth/Login" class="font-weight-bold text-accent">Quay lại đăng nhập</a>
                    </p>
                </div>
            </div>

        </div>
    </div>

    <script src="~/custom/notification.js"></script>
    <script src="~/custom/auth/forgotpassword.js"></script>
</body>
</html>