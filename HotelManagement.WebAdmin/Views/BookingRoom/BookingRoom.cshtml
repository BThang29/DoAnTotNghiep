
@{
    ViewData["Title"] = "BookingRoom";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý đặt phòng</h1>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Danh sách đặt phòng</h6>
                    <div class="mt-3 mt-lg-0 text-muted small" id="bookingRoomSummary">Đang tải dữ liệu...</div>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-lg-4 mb-3 mb-lg-0">
                            <input type="text" class="form-control" id="bookingRoomKeyword" placeholder="Tìm theo khách hàng hoặc phòng">
                        </div>
                        <div class="col-sm-6 col-lg-2 mb-3 mb-lg-0">
                            <input type="number" min="1" class="form-control" id="bookingRoomCustomerId" placeholder="Customer ID">
                        </div>
                        <div class="col-sm-6 col-lg-2 mb-3 mb-lg-0">
                            <select class="form-control" id="bookingRoomRoomId">
                                <option value="">Tất cả phòng</option>
                            </select>
                        </div>
                        <div class="col-sm-6 col-lg-2 mb-3 mb-sm-0">
                            <select class="form-control" id="bookingRoomSortBy">
                                <option value="id">ID</option>
                                <option value="customerName">Khách hàng</option>
                                <option value="roomName">Phòng</option>
                                <option value="dateBooking">Ngày đặt</option>
                                <option value="dateStart">Ngày nhận</option>
                                <option value="dateEnd">Ngày trả</option>
                                <option value="deposit">Tiền cọc</option>
                            </select>
                        </div>
                        <div class="col-sm-6 col-lg-2">
                            <select class="form-control" id="bookingRoomSortDesc">
                                <option value="false">Tăng dần</option>
                                <option value="true">Giảm dần</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                        <div class="mb-2 mb-md-0">
                            <button type="button" class="btn btn-success btn-sm" id="bookingRoomCreateButton">
                                <i class="fas fa-plus fa-sm"></i> Thêm mới
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" id="bookingRoomSearchButton">
                                <i class="fas fa-search fa-sm"></i> Tìm kiếm
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="bookingRoomResetButton">
                                Làm mới
                            </button>
                        </div>
                        <div class="d-flex align-items-center">
                            <label class="mb-0 mr-2 text-muted small" for="bookingRoomItemsPerPage">Hiển thị</label>
                            <select class="form-control form-control-sm w-auto" id="bookingRoomItemsPerPage">
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered" id="bookingRoomTable" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Mã khách hàng</th>
                                    <th>Khách hàng</th>
                                    <th>Phòng</th>
                                    <th>Ngày đặt</th>
                                    <th>Ngày nhận</th>
                                    <th>Ngày trả</th>
                                    <th>Tiền cọc</th>
                                    <th class="text-center admin-col-w-90">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="bookingRoomTableBody">
                                <tr>
                                    <td colspan="8" class="text-center text-muted">Đang tải dữ liệu...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <div class="text-muted small mb-2 mb-md-0" id="bookingRoomPaginationInfo">Chưa có dữ liệu.</div>
                        <nav aria-label="Booking room pagination">
                            <ul class="pagination pagination-sm mb-0" id="bookingRoomPagination"></ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bookingRoomDetailModal" tabindex="-1" role="dialog" aria-labelledby="bookingRoomDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header booking-room-detail-header border-0">
                <div>
                    <div class="booking-room-detail-kicker">Booking Room</div>
                    <h5 class="modal-title mb-1" id="bookingRoomDetailModalLabel">Chi tiết đặt phòng</h5>
                    <div class="booking-room-detail-subtitle">Thông tin tổng quan về khách hàng, phòng và thanh toán.</div>
                </div>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body booking-room-detail-body pt-0">
                <div class="booking-room-detail-hero">
                    <div class="booking-room-detail-hero-main">
                        <div class="booking-room-detail-label">Mã booking</div>
                        <div class="booking-room-detail-primary" id="bookingRoomDetailId">-</div>
                        <div class="booking-room-detail-meta">
                            <span>Ngày đặt:</span>
                            <strong id="bookingRoomDetailDateBooking">-</strong>
                        </div>
                    </div>
                    <div class="booking-room-detail-hero-side">
                        <div class="booking-room-detail-stat">
                            <span class="booking-room-detail-stat-label">Ngày nhận</span>
                            <span class="booking-room-detail-stat-value" id="bookingRoomDetailDateStart">-</span>
                        </div>
                        <div class="booking-room-detail-stat">
                            <span class="booking-room-detail-stat-label">Ngày trả</span>
                            <span class="booking-room-detail-stat-value" id="bookingRoomDetailDateEnd">-</span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-lg-4 mb-4">
                        <div class="booking-room-detail-card">
                            <div class="booking-room-detail-card-title">Khách hàng</div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Tên khách hàng</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailCustomerName">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Số điện thoại</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailCustomerPhone">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Mã khách hàng</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailCustomerId">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Mã nhân viên</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailEmployeeId">-</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="booking-room-detail-card">
                            <div class="booking-room-detail-card-title">Phòng</div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Tên phòng</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailRoomName">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Mã phòng</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailRoomId">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Giá phòng</span>
                                <strong class="booking-room-detail-field-value text-primary" id="bookingRoomDetailRoomPrice">-</strong>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 mb-4">
                        <div class="booking-room-detail-card">
                            <div class="booking-room-detail-card-title">Thanh toán</div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Tiền cọc</span>
                                <strong class="booking-room-detail-field-value text-success" id="bookingRoomDetailDeposit">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Voucher</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailVoucherCode">-</strong>
                            </div>
                            <div class="booking-room-detail-field">
                                <span class="booking-room-detail-field-label">Mã voucher</span>
                                <strong class="booking-room-detail-field-value" id="bookingRoomDetailVoucherId">-</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer booking-room-detail-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link href="~/custom/booking-room/booking-room.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="~/custom/booking-room/booking-room.js" asp-append-version="true"></script>
}

