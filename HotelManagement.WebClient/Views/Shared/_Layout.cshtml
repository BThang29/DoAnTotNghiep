    <link rel="stylesheet" href="/css/notification.css" asp-append-version="true" type="text/css">
    <link rel="stylesheet" href="/css/client-chat.css" asp-append-version="true" type="text/css">
    <link rel="stylesheet" href="/css/telly-pages.css" asp-append-version="true" type="text/css">
    @await RenderSectionAsync("Styles", required: false)
    <script src="/telly/js/modernizr.js"></script>
    <style>
        .telly-topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1031; background: #fff; border-bottom: 1px solid #ededed; height: 44px; font-size: .85rem; }
        .telly-topbar a { text-decoration: none; color: #16181d; }
        .telly-topbar .tb-contact i { color: #ff8103; margin-right: 6px; }
        .telly-topbar .tb-contact span { margin-right: 24px; white-space: nowrap; }
        .telly-topbar .tb-social a {
          align-items: center;
          background: #f7f7f7;
          border: 1px solid #ececec;
          border-radius: 50%;
          display: inline-flex;
          font-size: .82rem;
          height: 28px;
          justify-content: center;
          margin: 0 4px;
          text-decoration: none;
          transition: background .2s ease, border-color .2s ease, color .2s ease, transform .2s ease;
          width: 28px;
        }
        .telly-topbar .tb-social a:hover {
          background: #fff;
          border-color: currentColor;
          transform: translateY(-1px);
        }
        .telly-topbar .tb-social a[aria-label="Facebook"] { color: #1877f2; }
        .telly-topbar .tb-social a[aria-label="Twitter"] { color: #1da1f2; }
        .telly-topbar .tb-social a[aria-label="YouTube"] { color: #ff0000; }
        .telly-topbar .tb-social a[aria-label="Instagram"] { color: #e4405f; }
        .telly-topbar .tb-book { background: #ff8103; color: #fff; padding: 0 24px; height: 44px; display: inline-flex; align-items: center; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; font-size: .78rem; border: 0; cursor: pointer; text-decoration: none; }
        .telly-topbar .tb-book:hover { filter: brightness(.93); color: #fff; }
        .telly-topbar .tb-lang { position: relative; height: 44px; }
        .telly-topbar .tb-lang-toggle {
          height: 44px;
          min-width: 96px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          border: 0;
          border-left: 1px solid #ededed;
          border-radius: 0;
          background: #fff;
          color: #16181d;
          font-size: 1rem;
          font-weight: 500;
          line-height: 1;
          padding: 0 16px;
        }
        .telly-topbar .tb-lang-toggle::after { display: none; }
        .telly-topbar .tb-lang-toggle:hover,
        .telly-topbar .tb-lang-toggle:focus {
          background: #fff;
          color: #16181d;
          box-shadow: none;
        }
        .telly-topbar .tb-lang-flag {
          width: 26px;
          height: 26px;
          border-radius: 50%;
          object-fit: cover;
          box-shadow: 0 0 0 1px rgba(0,0,0,.08);
        }
        .telly-topbar .tb-lang-chevron {
          font-size: 16px;
          line-height: 1;
          margin-top: 1px;
        }
        .telly-topbar .tb-lang-menu {
          min-width: 132px;
          padding: 8px;
          border: 1px solid #ededed;
          border-radius: 0;
          box-shadow: 0 12px 30px rgba(15,23,42,.12);
        }
        .telly-topbar .tb-lang-menu .dropdown-item {
          display: flex;
          align-items: center;
          gap: 10px;
          border-radius: 4px;
          padding: 8px 10px;
          color: #16181d;
          font-weight: 500;
        }
        .telly-topbar .tb-lang-menu .dropdown-item:hover,
        .telly-topbar .tb-lang-menu .dropdown-item.active {
          background: #f5f5f5;
          color: #16181d;
        }
        #header-nav.navbar.fixed-top { top: 44px; }
        #header #navbar .nav-link {
          position: relative;
          display: inline-flex;
          border-bottom: 2px solid transparent;
          padding-bottom: 7px;
        }
        #header #navbar .nav-link.active {
          border-bottom-color: #fff !important;
        }
        #header #navbar .nav-link.active::after {
          content: "";
          display: none !important;
        }
        @@media (max-width: 575.98px) { .telly-topbar { font-size: .72rem; } .telly-topbar .tb-book { padding: 0 12px; } }
    </style>
</head>
<body class="@__bodyClass">
  <!-- Top bar -->
  <div class="telly-topbar d-flex align-items-center">
    <div class="container-fluid d-flex align-items-center justify-content-between h-100 ps-3 pe-0">
      <div class="tb-contact d-flex align-items-center">
                <span><i class="fa fa-phone"></i>079 559 6255</span>
                <span class="d-none d-sm-inline"><i class="fa fa-envelope"></i>thang7789o@gmail.com</span>
      </div>
      <div class="d-flex align-items-center h-100">
        <div class="tb-social d-none d-md-flex align-items-center me-3">
          <a href="#" aria-label="Facebook"><i class="fa fa-facebook"></i></a>
          <a href="#" aria-label="Twitter"><i class="fa fa-twitter"></i></a>
          <a href="#" aria-label="YouTube"><i class="fa fa-youtube-play"></i></a>
          <a href="#" aria-label="Instagram"><i class="fa fa-instagram"></i></a>
        </div>
        <div class="tb-lang dropdown d-none d-sm-flex">
          <button class="tb-lang-toggle dropdown-toggle" type="button" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="/images/vn-flag.jpg" alt="Tiếng Việt" class="tb-lang-flag">
            <span>VN</span>
            <i class="fa fa-angle-down tb-lang-chevron" aria-hidden="true"></i>
          </button>
          <ul class="dropdown-menu dropdown-menu-end tb-lang-menu" aria-labelledby="languageDropdown">
            <li>
              <a class="dropdown-item active" href="#" data-lang="vi">
                <img src="/images/vn-flag.jpg" alt="Tiếng Việt" class="tb-lang-flag">
                <span>VN</span>
              </a>
            </li>
            <li>
              <a class="dropdown-item" href="#" data-lang="en">
                <img src="/images/flag.jpg" alt="English" class="tb-lang-flag">
                <span>EN</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Video Popup -->
  <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-body">
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"><svg class="bi" width="40"
              height="40">
              <use xlink:href="#close-sharp"></use>
            </svg></button>
          <div class="ratio ratio-16x9">
            <iframe class="embed-responsive-item" src="" id="video" allowscriptaccess="always"
              allow="autoplay"></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>

