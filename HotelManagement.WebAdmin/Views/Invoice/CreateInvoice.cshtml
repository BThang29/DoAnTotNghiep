@{
    ViewData["Title"] = "Create Invoice";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid invoice-create-workspace">
    <div class="invoice-create-hero">
        <div>
            <div class="invoice-create-kicker">Invoice builder</div>
            <h1>Tạo hóa đơn</h1>
            <p>Chọn booking, khai báo thanh toán, thêm dịch vụ và xem bảng tính trước khi lưu hóa đơn.</p>
        </div>
        <a class="btn invoice-back-btn" asp-controller="Invoice" asp-action="Invoices">
            <i class="fas fa-arrow-left fa-sm"></i>
            Quay lại danh sách
        </a>
    </div>

    <section class="invoice-builder-grid">
        <div class="invoice-builder-card booking-card">
            <div class="invoice-card-head">
                <div>
                    <span>01</span>
                    <h2>Booking</h2>
                </div>
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="form-group">
                <label for="invoiceCreateBookingId">Booking</label>
                <select class="form-control" id="invoiceCreateBookingId">
                    <option value="">Chọn booking</option>
                </select>
                <small>Danh sách này lấy từ hệ thống booking.</small>
            </div>
            <div class="invoice-date-grid">
                <div class="form-group">
                    <label for="invoiceBookingDateStart">Ngày nhận phòng</label>
                    <input type="text" class="form-control" id="invoiceBookingDateStart" readonly placeholder="Chưa chọn booking">
                </div>
                <div class="form-group">
                    <label for="invoiceBookingDateEnd">Ngày trả phòng</label>
                    <input type="text" class="form-control" id="invoiceBookingDateEnd" readonly placeholder="Chưa chọn booking">
                </div>
            </div>
        </div>

        <div class="invoice-builder-card payment-card">
            <div class="invoice-card-head">
                <div>
                    <span>02</span>
                    <h2>Thanh toán</h2>
                </div>
                <i class="fas fa-credit-card"></i>
            </div>
            <div class="form-group">
                <label for="invoiceCreatePaymentDetails">Thông tin thanh toán</label>
                <textarea class="form-control" id="invoiceCreatePaymentDetails" rows="6" placeholder="Ví dụ: Đã thanh toán tiền mặt, thẻ, chuyển khoản..."></textarea>
            </div>
        </div>

        <div class="invoice-builder-card service-card">
            <div class="invoice-card-head">
                <div>
                    <span>03</span>
                    <h2>Dịch vụ</h2>
                </div>
                <i class="fas fa-concierge-bell"></i>
            </div>
            <div class="form-group">
                <label for="invoiceServiceSelect">Dịch vụ</label>
                <select class="form-control" id="invoiceServiceSelect">
                    <option value="">Chọn dịch vụ</option>
                </select>
            </div>
            <div class="invoice-service-input-grid">
                <div class="form-group">
                    <label for="invoiceServiceQuantity">Số lượng</label>
                    <input type="number" min="1" class="form-control" id="invoiceServiceQuantity" value="1">
                </div>
                <div class="form-group">
                    <label for="invoiceServiceUseDate">Ngày sử dụng</label>
                    <input type="date" class="form-control" id="invoiceServiceUseDate">
                </div>
                <div class="form-group invoice-service-voucher-field">
                    <label for="invoiceServiceVoucherId">Voucher ID</label>
                    <input type="number" min="1" class="form-control" id="invoiceServiceVoucherId" placeholder="Không bắt buộc">
                </div>
            </div>
            <button type="button" class="btn btn-outline-primary" id="invoiceAddServiceButton">
                <i class="fas fa-plus fa-sm"></i>
                Thêm dịch vụ
            </button>
        </div>
    </section>

    <section class="invoice-service-cart">
        <div class="invoice-cart-head">
            <div>
                <div class="invoice-create-kicker">Service cart</div>
                <h2>Danh sách dịch vụ sẽ tính</h2>
            </div>
            <span id="invoiceSelectedServicesCount">0 dòng</span>
        </div>
        <div id="invoiceSelectedServicesEmpty" class="invoice-cart-empty">Chưa có dịch vụ nào được thêm.</div>
        <div id="invoiceSelectedServicesList" class="invoice-service-list"></div>
    </section>

    <section class="invoice-calculation-panel">
        <div class="invoice-calc-head">
            <div>
                <div class="invoice-create-kicker">Calculation</div>
                <h2>Bảng tính hóa đơn</h2>
                <p>Nhấn "Tính hóa đơn" để xem tổng hợp trước khi lưu.</p>
            </div>
            <div class="invoice-calc-actions">
                <button type="button" class="btn btn-info" id="invoiceCalculateButton">
                    <i class="fas fa-calculator fa-sm"></i>
                    Tính hóa đơn
                </button>
                <button type="button" class="btn btn-primary" id="invoiceSubmitButton">
                    <i class="fas fa-save fa-sm"></i>
                    Lưu hóa đơn
                </button>
            </div>
        </div>

        <div id="invoiceCalculationPlaceholder" class="invoice-placeholder-state">
            Chọn booking và bấm "Tính hóa đơn" để xem chi tiết.
        </div>

        <div id="invoiceCalculationContent" class="d-none">
            <div class="invoice-calc-hero">
                <div>
                    <div class="invoice-calc-kicker">Booking</div>
                    <div class="invoice-calc-primary" id="invoiceCalcBookingText">-</div>
                    <div class="invoice-calc-secondary" id="invoiceCalcCustomerText">-</div>
                </div>
                <div class="invoice-calc-room">
                    <span class="invoice-calc-room-label">Phòng</span>
                    <strong id="invoiceCalcRoomText">-</strong>
                </div>
            </div>

            <div class="invoice-summary-grid">
                <div class="invoice-summary-box">
                    <span>Số đêm</span>
                    <strong id="invoiceCalcNights">0</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Giá phòng</span>
                    <strong id="invoiceCalcRoomUnitPrice">0 VND</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Tiền phòng</span>
                    <strong id="invoiceCalcRoomCharge">0 VND</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Tiền dịch vụ</span>
                    <strong id="invoiceCalcServiceCharge">0 VND</strong>
                </div>
            </div>

            <div class="invoice-line-table-shell">
                <table class="table table-sm invoice-line-table mb-0">
                    <thead>
                        <tr>
                            <th>Dịch vụ</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Voucher</th>
                            <th>Ngày dùng</th>
                            <th class="text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceCalculationLines">
                        <tr>
                            <td colspan="6" class="text-center text-muted">Chưa có dịch vụ.</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="invoice-total-bar">
                <span>Tổng thanh toán</span>
                <strong id="invoiceCalcTotalAmount">0 VND</strong>
            </div>
        </div>
    </section>
</div>

@section Styles {
    <link href="~/custom/invoice/create-invoice.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="~/custom/invoice/create-invoice.js" asp-append-version="true"></script>
    <script src="~/custom/invoice/calculate-invoice.js" asp-append-version="true"></script>
}
