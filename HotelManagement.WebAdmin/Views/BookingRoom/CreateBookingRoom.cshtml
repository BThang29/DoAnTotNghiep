@{
    ViewData["Title"] = "CreateBookingRoom";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="container-fluid create-booking-workspace">
    <div class="create-booking-hero">
        <div>
            <div class="create-booking-kicker">Booking workspace</div>
            <h1>Tạo đặt phòng</h1>
            <p>Nhập thông tin khách, chọn thời gian lưu trú và kiểm tra phòng trống trong cùng một luồng thao tác.</p>
        </div>
        <a href="/BookingRoom/BookingRoom" class="btn create-booking-back-btn">
            <i class="fas fa-arrow-left fa-sm"></i>
            Quay lại danh sách
        </a>
    </div>

    <div class="create-booking-layout">
        <main class="create-booking-main">
            <section class="create-booking-step">
                <div class="create-booking-step-marker">01</div>
                <div class="create-booking-step-body">
                    <div class="create-booking-step-header">
                        <div>
                            <h2>Thông tin khách hàng</h2>
                            <p>Chọn khách đã có hoặc nhập nhanh hồ sơ khách mới.</p>
                        </div>
                        <button type="button" class="btn btn-outline-primary" id="createBookingOpenCustomerModalButton">
                            <i class="fas fa-users fa-sm"></i>
                            Chọn khách có sẵn
                        </button>
                    </div>

                    <div class="create-booking-selected-customer">
                        <div>
                            <span>Khách hàng đã chọn</span>
                            <strong id="createBookingSelectedCustomerName">Chưa chọn khách hàng có sẵn</strong>
                            <small id="createBookingSelectedCustomerMeta">Bạn có thể chọn từ danh sách hoặc nhập khách hàng mới bên dưới.</small>
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="createBookingClearCustomerButton">
                            Bỏ chọn
                        </button>
                        <input type="hidden" id="createBookingCustomerId">
                    </div>

                    <div class="create-booking-form-grid">
                        <div class="form-group is-wide">
                            <label for="createBookingCustomerFullName">Tên khách hàng</label>
                            <input type="text" class="form-control" id="createBookingCustomerFullName" placeholder="Nhập tên khách hàng mới nếu chưa có trong hệ thống">
                        </div>
                        <div class="form-group">
                            <label for="createBookingCustomerPhone">Số điện thoại</label>
                            <input type="text" class="form-control" id="createBookingCustomerPhone" placeholder="0909xxxxxx">
                        </div>
                        <div class="form-group">
                            <label for="createBookingCustomerIdentify">CCCD/CMND</label>
                            <input type="text" class="form-control" id="createBookingCustomerIdentify" placeholder="Không bắt buộc">
                        </div>
                        <div class="form-group">
                            <label for="createBookingCustomerTypeId">Loại khách hàng</label>
                            <select class="form-control" id="createBookingCustomerTypeId">
                                <option value="">Đang tải loại khách hàng...</option>
                            </select>
                        </div>
                        <div class="form-group is-wide">
                            <label for="createBookingCustomerEmail">Email</label>
                            <input type="email" class="form-control" id="createBookingCustomerEmail" placeholder="example@email.com">
                        </div>
                        <div class="form-group">
                            <label for="createBookingCustomerDob">Ngày sinh</label>
                            <input type="date" class="form-control" id="createBookingCustomerDob">
                        </div>
                    </div>
                </div>
            </section>

            <section class="create-booking-step">
                <div class="create-booking-step-marker">02</div>
                <div class="create-booking-step-body">
                    <div class="create-booking-step-header">
                        <div>
                            <h2>Thời gian lưu trú</h2>
                            <p>Thiết lập ngày nhận, ngày trả và thông tin thanh toán ban đầu.</p>
                        </div>
                    </div>

                    <div class="create-booking-form-grid create-booking-three-grid">
                        <div class="form-group">
                            <label for="createBookingDateStart">Ngày nhận phòng</label>
                            <input type="date" class="form-control" id="createBookingDateStart" min="@today">
                        </div>
                        <div class="form-group">
                            <label for="createBookingDateEnd">Ngày trả phòng</label>
                            <input type="date" class="form-control" id="createBookingDateEnd" min="@today">
                        </div>
                        <div class="form-group">
                            <label for="createBookingDeposit">Tiền cọc</label>
                            <input type="number" min="0" step="1000" class="form-control" id="createBookingDeposit" placeholder="Ví dụ: 200000">
                        </div>
                        <div class="form-group">
                            <label for="createBookingVoucherId">Voucher ID</label>
                            <input type="number" min="1" class="form-control" id="createBookingVoucherId" placeholder="Không bắt buộc">
                        </div>
                    </div>
                </div>
            </section>

            <section class="create-booking-step">
                <div class="create-booking-step-marker">03</div>
                <div class="create-booking-step-body">
                    <div class="create-booking-step-header">
                        <div>
                            <h2>Chọn phòng</h2>
                            <p id="createBookingRoomHelpText">Chọn ngày và loại phòng để kiểm tra phòng trống.</p>
                        </div>
                        <button type="button" class="btn btn-primary" id="createBookingCheckRoomButton">
                            <i class="fas fa-search fa-sm"></i>
                            Kiểm tra phòng trống
                        </button>
                    </div>

                    <div class="create-booking-form-grid">
                        <div class="form-group">
                            <label for="createBookingRoomTypeId">Loại phòng</label>
                            <select class="form-control" id="createBookingRoomTypeId">
                                <option value="">Tất cả loại phòng</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="createBookingRoomId">Phòng trống</label>
                            <select class="form-control" id="createBookingRoomId">
                                <option value="">Chưa có dữ liệu phòng</option>
                            </select>
                            <small id="createBookingSelectedRoomPrice">Giá phòng: -</small>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <aside class="create-booking-summary-card">
            <div class="create-booking-summary-head">
                <div>
                    <span>Preview</span>
                    <h2>Tóm tắt booking</h2>
                </div>
                <i class="fas fa-clipboard-check"></i>
            </div>

            <div class="create-booking-summary-item">
                <span>Khách hàng</span>
                <strong id="createBookingSummaryCustomer">-</strong>
            </div>
            <div class="create-booking-summary-item">
                <span>Khoảng thời gian</span>
                <strong id="createBookingSummaryDate">-</strong>
            </div>
            <div class="create-booking-summary-item">
                <span>Phòng</span>
                <strong id="createBookingSummaryRoom">-</strong>
            </div>
            <div class="create-booking-summary-item">
                <span>Tiền cọc</span>
                <strong id="createBookingSummaryDeposit">-</strong>
            </div>
            <div class="create-booking-summary-item">
                <span>Voucher ID</span>
                <strong id="createBookingSummaryVoucher">-</strong>
            </div>

            <div class="create-booking-status-box" id="createBookingStatusText">Điền đầy đủ thông tin để tạo booking.</div>

            <div class="create-booking-actions">
                <a href="/BookingRoom/BookingRoom" class="btn btn-outline-secondary">Hủy</a>
                <button type="button" class="btn btn-success" id="createBookingSubmitButton">
                    <i class="fas fa-save fa-sm"></i>
                    Tạo đặt phòng
                </button>
            </div>
        </aside>
    </div>
</div>

<div class="modal fade" id="createBookingCustomerModal" tabindex="-1" role="dialog" aria-labelledby="createBookingCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="createBookingCustomerModalLabel">Chọn khách hàng có sẵn</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group mb-3">
                    <input type="text" class="form-control" id="createBookingCustomerSearchKeyword" placeholder="Tìm theo tên, số điện thoại, CCCD hoặc email">
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Khách hàng</th>
                                <th>Số điện thoại</th>
                                <th>CCCD/CMND</th>
                                <th>Email</th>
                                <th class="text-center" style="width: 90px;">Chọn</th>
                            </tr>
                        </thead>
                        <tbody id="createBookingCustomerTableBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted">Đang tải khách hàng...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .create-booking-workspace {
        color: #182230;
    }

    .create-booking-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1.25rem;
        border: 1px solid #dbe5e4;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
    }

    .create-booking-kicker {
        margin-bottom: 0.35rem;
        color: #0f8f83;
        font-size: 0.74rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .create-booking-hero h1 {
        margin: 0;
        color: #182230;
        font-size: 1.55rem;
        font-weight: 850;
        letter-spacing: 0;
    }

    .create-booking-hero p {
        max-width: 720px;
        margin: 0.45rem 0 0;
        color: #667085;
        line-height: 1.6;
    }

    .create-booking-back-btn {
        flex: 0 0 auto;
        border: 1px solid #cfd8df;
        border-radius: 6px;
        color: #344054;
        background: #fff;
        font-weight: 800;
    }

    .create-booking-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 1rem;
        align-items: start;
    }

    .create-booking-main {
        display: grid;
        gap: 1rem;
    }

    .create-booking-step {
        display: grid;
        grid-template-columns: 56px minmax(0, 1fr);
        gap: 0.85rem;
    }

    .create-booking-step-marker {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border: 1px solid #cfe2df;
        border-radius: 8px;
        color: #0b7068;
        background: #eef8f6;
        font-size: 0.82rem;
        font-weight: 900;
    }

    .create-booking-step-body,
    .create-booking-summary-card {
        border: 1px solid #dfe7ec;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
    }

    .create-booking-step-body {
        padding: 1.15rem;
    }

    .create-booking-step-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .create-booking-step-header h2 {
        margin: 0;
        color: #182230;
        font-size: 1.05rem;
        font-weight: 850;
    }

    .create-booking-step-header p {
        margin: 0.35rem 0 0;
        color: #667085;
        font-size: 0.9rem;
    }

    .create-booking-selected-customer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 0.9rem;
        border: 1px solid #cfe2df;
        border-radius: 8px;
        background: #f7fbfa;
    }

    .create-booking-selected-customer span,
    .create-booking-summary-item span,
    .create-booking-summary-head span {
        display: block;
        color: #667085;
        font-size: 0.78rem;
        font-weight: 800;
    }

    .create-booking-selected-customer strong {
        display: block;
        margin-top: 0.2rem;
        color: #182230;
        font-weight: 850;
    }

    .create-booking-selected-customer small {
        display: block;
        margin-top: 0.2rem;
        color: #667085;
    }

    .create-booking-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .create-booking-three-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .create-booking-form-grid .form-group {
        margin-bottom: 0;
    }

    .create-booking-form-grid .is-wide {
        grid-column: span 2;
    }

    .create-booking-workspace label {
        margin-bottom: 0.4rem;
        color: #344054;
        font-size: 0.82rem;
        font-weight: 850;
    }

    .create-booking-workspace .form-control {
        min-height: 42px;
        border-color: #d7e0e7;
        border-radius: 6px;
        color: #1f2937;
        box-shadow: none;
    }

    .create-booking-workspace .form-control:focus {
        border-color: #0f8f83;
        box-shadow: 0 0 0 0.18rem rgba(15, 143, 131, 0.13);
    }

    .create-booking-workspace .btn {
        border-radius: 6px;
        font-weight: 800;
    }

    .create-booking-workspace .btn-primary,
    .create-booking-workspace .btn-success {
        border-color: #0f8f83;
        background: #0f8f83;
    }

    .create-booking-workspace .btn-primary:hover,
    .create-booking-workspace .btn-success:hover {
        border-color: #0b7068;
        background: #0b7068;
    }

    .create-booking-workspace .btn-outline-primary {
        border-color: #0f8f83;
        color: #0b7068;
    }

    .create-booking-workspace .btn-outline-primary:hover {
        background: #0f8f83;
        color: #fff;
    }

    #createBookingSelectedRoomPrice {
        display: block;
        margin-top: 0.45rem;
        color: #667085;
        font-weight: 700;
    }

    .create-booking-summary-card {
        position: sticky;
        top: 1rem;
        padding: 1.15rem;
    }

    .create-booking-summary-item {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.85rem 0;
        border-bottom: 1px solid #eef2f4;
    }

    .create-booking-summary-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 0.95rem;
        border-bottom: 1px solid #dfe7ec;
    }

    .create-booking-summary-head h2 {
        margin: 0.15rem 0 0;
        color: #182230;
        font-size: 1.1rem;
        font-weight: 850;
    }

    .create-booking-summary-head i {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 8px;
        color: #0b7068;
        background: #eef8f6;
    }

    .create-booking-summary-item strong {
        max-width: 58%;
        color: #182230;
        font-size: 0.95rem;
        font-weight: 850;
        text-align: right;
        word-break: break-word;
    }

    .create-booking-status-box {
        margin-top: 1rem;
        padding: 0.85rem;
        border: 1px solid #cfe2df;
        border-radius: 8px;
        color: #475467;
        background: #f7fbfa;
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.5;
    }

    .create-booking-actions {
        display: grid;
        grid-template-columns: 1fr 1.35fr;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .create-booking-actions .btn {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
    }

    .create-booking-loading {
        position: relative;
        pointer-events: none;
        opacity: 0.72;
    }

    .create-booking-loading::after {
        content: "";
        position: absolute;
        top: 50%;
        right: 14px;
        width: 16px;
        height: 16px;
        margin-top: -8px;
        border: 2px solid rgba(255, 255, 255, 0.45);
        border-top-color: #ffffff;
        border-radius: 50%;
        animation: create-booking-spin 0.8s linear infinite;
    }

    .btn-outline-primary.create-booking-loading::after,
    .btn-outline-secondary.create-booking-loading::after {
        border: 2px solid rgba(15, 143, 131, 0.2);
        border-top-color: #0f8f83;
    }

    @@keyframes create-booking-spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 1199.98px) {
        .create-booking-layout,
        .create-booking-three-grid {
            grid-template-columns: 1fr;
        }

        .create-booking-summary-card {
            position: static;
        }
    }

    @@media (max-width: 767.98px) {
        .create-booking-hero,
        .create-booking-step-header,
        .create-booking-selected-customer {
            flex-direction: column;
            align-items: stretch;
        }

        .create-booking-step {
            grid-template-columns: 1fr;
        }

        .create-booking-step-marker {
            width: 44px;
            height: 36px;
        }

        .create-booking-form-grid {
            grid-template-columns: 1fr;
        }

        .create-booking-form-grid .is-wide {
            grid-column: auto;
        }

        .create-booking-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

@section Scripts {
    <script src="~/custom/booking-room/create-booking-room.js" asp-append-version="true"></script>
}
