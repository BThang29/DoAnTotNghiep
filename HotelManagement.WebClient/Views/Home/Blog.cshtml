
@{
    ViewData["Title"] = "Tin tức";
}

<section class="tl-blog-page">
    <div class="tl-blog-hero">
        <div class="container">
            <span class="tl-blog-kicker">Telly Journal</span>
            <h1>Tin tức, cảm hứng du lịch và trải nghiệm lưu trú</h1>
            <p>Cập nhật những gợi ý nghỉ dưỡng, lịch trình khám phá Huế và các câu chuyện từ Telly Hotel.</p>
        </div>
    </div>

    <div class="container tl-blog-wrap">
        <article class="tl-blog-featured">
            <a href="#" class="tl-blog-featured__image">
                <img src="/images/blog/blog-wide.jpg" alt="Không gian nghỉ dưỡng tại Telly Hotel">
            </a>
            <div class="tl-blog-featured__content">
                <span class="tl-blog-tag">Stay Guide</span>
                <h2><a href="#">Một ngày trọn vẹn ở trung tâm Huế</a></h2>
                <p>Lịch trình gợi ý cho khách lưu trú tại Telly: cà phê sáng, dạo phố, bữa tối ven sông và trở về phòng nghỉ yên tĩnh.</p>
                <div class="tl-blog-meta">
                    <span><i class="fa fa-calendar-o"></i> 01 Tháng 6, 2026</span>
                    <span><i class="fa fa-clock-o"></i> 5 phút đọc</span>
                </div>
            </div>
        </article>

        <div class="tl-blog-toolbar">
            <div>
                <span class="tl-blog-toolbar__eyebrow">Bài viết mới</span>
                <h2>Khám phá thêm</h2>
            </div>
            <div class="tl-blog-filters" aria-label="Lọc tin tức">
                <button type="button" class="is-active">Tất cả</button>
                <button type="button">Du lịch</button>
                <button type="button">Ẩm thực</button>
                <button type="button">Khách sạn</button>
            </div>
        </div>

        <div class="tl-blog-grid">
            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-1.jpg" alt="Gợi ý check-in Huế">
                    <span>Travel Trip</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 15 Tháng 4, 2026</span></div>
                    <h3><a href="#">Những điểm check-in gần khách sạn trong một buổi chiều</a></h3>
                    <p>Gợi ý các điểm đến dễ đi bộ hoặc di chuyển nhanh từ khu trung tâm.</p>
                </div>
            </article>

            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-2.jpg" alt="Bữa sáng khách sạn">
                    <span>Hotel Life</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 18 Tháng 4, 2026</span></div>
                    <h3><a href="#">Bắt đầu ngày mới với nhịp sống chậm hơn</a></h3>
                    <p>Một vài thói quen nhỏ giúp kỳ nghỉ thành phố vẫn thư thái và đủ năng lượng.</p>
                </div>
            </article>

            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-3.jpg" alt="Du lịch gia đình">
                    <span>Family</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 21 Tháng 4, 2026</span></div>
                    <h3><a href="#">Lưu trú cùng gia đình: chọn phòng thế nào cho tiện?</a></h3>
                    <p>Các tiêu chí về diện tích, giường ngủ và tiện ích nên cân nhắc trước khi đặt phòng.</p>
                </div>
            </article>

            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-4.jpg" alt="Quán cà phê Huế">
                    <span>Coffee</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 22 Tháng 4, 2026</span></div>
                    <h3><a href="#">Những quán cà phê yên tĩnh cho buổi sáng làm việc</a></h3>
                    <p>Danh sách nhỏ dành cho khách công tác muốn đổi không gian làm việc.</p>
                </div>
            </article>

            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-5.jpg" alt="Ẩm thực địa phương">
                    <span>Dining</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 25 Tháng 4, 2026</span></div>
                    <h3><a href="#">Ăn gì quanh khách sạn khi chỉ có một đêm ở Huế?</a></h3>
                    <p>Các lựa chọn gần, dễ đi, hợp cho cả bữa tối nhẹ hoặc cuộc hẹn thân mật.</p>
                </div>
            </article>

            <article class="tl-blog-card">
                <a href="#" class="tl-blog-card__image">
                    <img src="/images/blog/blog-6.jpg" alt="Kỳ nghỉ cuối tuần">
                    <span>Weekend</span>
                </a>
                <div class="tl-blog-card__body">
                    <div class="tl-blog-meta"><span><i class="fa fa-calendar-o"></i> 28 Tháng 4, 2026</span></div>
                    <h3><a href="#">Kỳ nghỉ cuối tuần gọn nhẹ cho người bận rộn</a></h3>
                    <p>Cách lên lịch hai ngày một đêm vừa đủ nghỉ, vừa đủ khám phá thành phố.</p>
                </div>
            </article>
        </div>

        <div class="tl-blog-more">
            <a href="#" class="tl-blog-more__button">Xem thêm bài viết <i class="fa fa-long-arrow-right"></i></a>
        </div>
    </div>
</section>
