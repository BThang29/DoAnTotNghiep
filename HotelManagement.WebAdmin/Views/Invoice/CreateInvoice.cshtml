@{
    ViewData["Title"] = "Create Invoice";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid invoice-create-workspace">
    <div class="invoice-create-hero">
        <div>
            <div class="invoice-create-kicker">Invoice builder</div>
            <h1>Tạo hóa đơn</h1>
            <p>Chọn booking, khai báo thanh toán, thêm dịch vụ và xem bảng tính trước khi lưu hóa đơn.</p>
        </div>
        <a class="btn invoice-back-btn" asp-controller="Invoice" asp-action="Invoices">
            <i class="fas fa-arrow-left fa-sm"></i>
            Quay lại danh sách
        </a>
    </div>

    <section class="invoice-builder-grid">
        <div class="invoice-builder-card booking-card">
            <div class="invoice-card-head">
                <div>
                    <span>01</span>
                    <h2>Booking</h2>
                </div>
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="form-group">
                <label for="invoiceCreateBookingId">Booking</label>
                <select class="form-control" id="invoiceCreateBookingId">
                    <option value="">Chọn booking</option>
                </select>
                <small>Danh sách này lấy từ hệ thống booking.</small>
            </div>
            <div class="invoice-date-grid">
                <div class="form-group">
                    <label for="invoiceBookingDateStart">Ngày nhận phòng</label>
                    <input type="text" class="form-control" id="invoiceBookingDateStart" readonly placeholder="Chưa chọn booking">
                </div>
                <div class="form-group">
                    <label for="invoiceBookingDateEnd">Ngày trả phòng</label>
                    <input type="text" class="form-control" id="invoiceBookingDateEnd" readonly placeholder="Chưa chọn booking">
                </div>
            </div>
        </div>

        <div class="invoice-builder-card payment-card">
            <div class="invoice-card-head">
                <div>
                    <span>02</span>
                    <h2>Thanh toán</h2>
                </div>
                <i class="fas fa-credit-card"></i>
            </div>
            <div class="form-group">
                <label for="invoiceCreatePaymentDetails">Thông tin thanh toán</label>
                <textarea class="form-control" id="invoiceCreatePaymentDetails" rows="6" placeholder="Ví dụ: Đã thanh toán tiền mặt, thẻ, chuyển khoản..."></textarea>
            </div>
        </div>

        <div class="invoice-builder-card service-card">
            <div class="invoice-card-head">
                <div>
                    <span>03</span>
                    <h2>Dịch vụ</h2>
                </div>
                <i class="fas fa-concierge-bell"></i>
            </div>
            <div class="form-group">
                <label for="invoiceServiceSelect">Dịch vụ</label>
                <select class="form-control" id="invoiceServiceSelect">
                    <option value="">Chọn dịch vụ</option>
                </select>
            </div>
            <div class="invoice-service-input-grid">
                <div class="form-group">
                    <label for="invoiceServiceQuantity">Số lượng</label>
                    <input type="number" min="1" class="form-control" id="invoiceServiceQuantity" value="1">
                </div>
                <div class="form-group">
                    <label for="invoiceServiceUseDate">Ngày sử dụng</label>
                    <input type="date" class="form-control" id="invoiceServiceUseDate">
                </div>
                <div class="form-group invoice-service-voucher-field">
                    <label for="invoiceServiceVoucherId">Voucher ID</label>
                    <input type="number" min="1" class="form-control" id="invoiceServiceVoucherId" placeholder="Không bắt buộc">
                </div>
            </div>
            <button type="button" class="btn btn-outline-primary" id="invoiceAddServiceButton">
                <i class="fas fa-plus fa-sm"></i>
                Thêm dịch vụ
            </button>
        </div>
    </section>

    <section class="invoice-service-cart">
        <div class="invoice-cart-head">
            <div>
                <div class="invoice-create-kicker">Service cart</div>
                <h2>Danh sách dịch vụ sẽ tính</h2>
            </div>
            <span id="invoiceSelectedServicesCount">0 dòng</span>
        </div>
        <div id="invoiceSelectedServicesEmpty" class="invoice-cart-empty">Chưa có dịch vụ nào được thêm.</div>
        <div id="invoiceSelectedServicesList" class="invoice-service-list"></div>
    </section>

    <section class="invoice-calculation-panel">
        <div class="invoice-calc-head">
            <div>
                <div class="invoice-create-kicker">Calculation</div>
                <h2>Bảng tính hóa đơn</h2>
                <p>Nhấn "Tính hóa đơn" để xem tổng hợp trước khi lưu.</p>
            </div>
            <div class="invoice-calc-actions">
                <button type="button" class="btn btn-info" id="invoiceCalculateButton">
                    <i class="fas fa-calculator fa-sm"></i>
                    Tính hóa đơn
                </button>
                <button type="button" class="btn btn-primary" id="invoiceSubmitButton">
                    <i class="fas fa-save fa-sm"></i>
                    Lưu hóa đơn
                </button>
            </div>
        </div>

        <div id="invoiceCalculationPlaceholder" class="invoice-placeholder-state">
            Chọn booking và bấm "Tính hóa đơn" để xem chi tiết.
        </div>

        <div id="invoiceCalculationContent" class="d-none">
            <div class="invoice-calc-hero">
                <div>
                    <div class="invoice-calc-kicker">Booking</div>
                    <div class="invoice-calc-primary" id="invoiceCalcBookingText">-</div>
                    <div class="invoice-calc-secondary" id="invoiceCalcCustomerText">-</div>
                </div>
                <div class="invoice-calc-room">
                    <span class="invoice-calc-room-label">Phòng</span>
                    <strong id="invoiceCalcRoomText">-</strong>
                </div>
            </div>

            <div class="invoice-summary-grid">
                <div class="invoice-summary-box">
                    <span>Số đêm</span>
                    <strong id="invoiceCalcNights">0</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Giá phòng</span>
                    <strong id="invoiceCalcRoomUnitPrice">0 VND</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Tiền phòng</span>
                    <strong id="invoiceCalcRoomCharge">0 VND</strong>
                </div>
                <div class="invoice-summary-box">
                    <span>Tiền dịch vụ</span>
                    <strong id="invoiceCalcServiceCharge">0 VND</strong>
                </div>
            </div>

            <div class="invoice-line-table-shell">
                <table class="table table-sm invoice-line-table mb-0">
                    <thead>
                        <tr>
                            <th>Dịch vụ</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Voucher</th>
                            <th>Ngày dùng</th>
                            <th class="text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceCalculationLines">
                        <tr>
                            <td colspan="6" class="text-center text-muted">Chưa có dịch vụ.</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="invoice-total-bar">
                <span>Tổng thanh toán</span>
                <strong id="invoiceCalcTotalAmount">0 VND</strong>
            </div>
        </div>
    </section>
</div>

<style>
    .invoice-create-workspace {
        color: #182230;
    }

    .invoice-create-hero,
    .invoice-builder-card,
    .invoice-service-cart,
    .invoice-calculation-panel {
        border: 1px solid #dfe7ec;
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
    }

    .invoice-create-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1.25rem;
    }

    .invoice-create-kicker {
        margin-bottom: 0.35rem;
        color: #0f8f83;
        font-size: 0.74rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .invoice-create-hero h1,
    .invoice-card-head h2,
    .invoice-cart-head h2,
    .invoice-calc-head h2 {
        margin: 0;
        color: #182230;
        font-weight: 850;
        letter-spacing: 0;
    }

    .invoice-create-hero h1 {
        font-size: 1.55rem;
    }

    .invoice-card-head h2,
    .invoice-cart-head h2,
    .invoice-calc-head h2 {
        font-size: 1.05rem;
    }

    .invoice-create-hero p,
    .invoice-calc-head p {
        max-width: 760px;
        margin: 0.45rem 0 0;
        color: #667085;
        line-height: 1.6;
    }

    .invoice-back-btn,
    .invoice-create-workspace .btn {
        border-radius: 6px;
        font-weight: 800;
    }

    .invoice-back-btn {
        flex: 0 0 auto;
        border: 1px solid #cfd8df;
        color: #344054;
        background: #fff;
    }

    .invoice-builder-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr) minmax(0, 1.25fr);
        gap: 1rem;
        margin-bottom: 1rem;
        align-items: stretch;
    }

    .invoice-builder-card,
    .invoice-service-cart,
    .invoice-calculation-panel {
        padding: 1rem;
    }

    .invoice-card-head,
    .invoice-cart-head,
    .invoice-calc-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 0.9rem;
        margin-bottom: 0.9rem;
        border-bottom: 1px solid #dfe7ec;
    }

    .invoice-card-head span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        height: 26px;
        margin-bottom: 0.3rem;
        border-radius: 999px;
        color: #0b7068;
        background: #eef8f6;
        font-size: 0.75rem;
        font-weight: 900;
    }

    .invoice-card-head i {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 8px;
        color: #0b7068;
        background: #eef8f6;
    }

    .invoice-create-workspace label {
        margin-bottom: 0.4rem;
        color: #344054;
        font-size: 0.82rem;
        font-weight: 850;
    }

    .invoice-create-workspace .form-control {
        min-height: 42px;
        border-color: #d7e0e7;
        border-radius: 6px;
        color: #1f2937;
        box-shadow: none;
    }

    .invoice-create-workspace textarea.form-control {
        min-height: 135px;
    }

    .invoice-create-workspace .form-control:focus {
        border-color: #0f8f83;
        box-shadow: 0 0 0 0.18rem rgba(15, 143, 131, 0.13);
    }

    .invoice-create-workspace small {
        display: block;
        margin-top: 0.4rem;
        color: #667085;
        font-weight: 700;
    }

    .invoice-create-workspace .btn-primary,
    .invoice-create-workspace .btn-info {
        min-height: 42px;
        border-color: #0f8f83;
        background: #0f8f83;
    }

    .invoice-create-workspace .btn-primary:hover,
    .invoice-create-workspace .btn-info:hover {
        border-color: #0b7068;
        background: #0b7068;
    }

    .invoice-create-workspace .btn-outline-primary {
        border-color: #0f8f83;
        color: #0b7068;
    }

    .invoice-create-workspace .btn-outline-primary:hover {
        color: #fff;
        background: #0f8f83;
    }

    .invoice-date-grid,
    .invoice-service-input-grid {
        display: grid;
        gap: 0.75rem;
    }

    .invoice-date-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .invoice-service-input-grid {
        grid-template-columns: 112px minmax(0, 1fr);
        row-gap: 0.95rem;
    }

    .invoice-service-input-grid .form-group,
    .invoice-date-grid .form-group {
        margin-bottom: 0;
    }

    .invoice-service-voucher-field {
        grid-column: 1 / -1;
        max-width: 240px;
    }

    #invoiceAddServiceButton {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 1rem;
    }

    .invoice-service-cart {
        margin-bottom: 1rem;
    }

    .invoice-cart-head {
        margin-bottom: 0;
    }

    #invoiceSelectedServicesCount {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 72px;
        min-height: 34px;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        color: #0b7068;
        background: #eef8f6;
        font-weight: 850;
    }

    .invoice-cart-empty {
        padding: 1rem 0 0;
        color: #667085;
        font-weight: 700;
    }

    .invoice-service-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        padding-top: 1rem;
    }

    .invoice-service-chip {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.85rem;
        border: 1px solid #dfe7ec;
        border-radius: 8px;
        background: #f7fbfa;
    }

    .invoice-service-chip strong {
        display: block;
        color: #182230;
        font-weight: 850;
    }

    .invoice-service-chip small {
        color: #667085;
        line-height: 1.5;
    }

    .invoice-calculation-panel {
        margin-bottom: 1rem;
    }

    .invoice-calc-head {
        align-items: center;
    }

    .invoice-calc-actions {
        display: flex;
        gap: 0.65rem;
        flex: 0 0 auto;
    }

    .invoice-placeholder-state {
        padding: 3rem 1.5rem;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f7fbfa;
        text-align: center;
        color: #64748b;
        font-weight: 750;
    }

    .invoice-calc-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1rem;
        border-radius: 8px;
        color: #fff;
        background: #0f8f83;
    }

    .invoice-calc-kicker {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.74rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .invoice-calc-primary {
        margin-top: 0.25rem;
        font-size: 1.35rem;
        font-weight: 900;
        line-height: 1.2;
    }

    .invoice-calc-secondary {
        margin-top: 0.25rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .invoice-calc-room {
        min-width: 180px;
        padding: 0.85rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.14);
        text-align: right;
    }

    .invoice-calc-room-label {
        display: block;
        color: rgba(255, 255, 255, 0.78);
        font-size: 0.82rem;
        font-weight: 800;
    }

    .invoice-calc-room strong {
        color: #fff;
        font-size: 1rem;
    }

    .invoice-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .invoice-summary-box {
        padding: 0.9rem;
        border: 1px solid #dfe7ec;
        border-radius: 8px;
        background: #fff;
    }

    .invoice-summary-box span {
        display: block;
        color: #667085;
        font-size: 0.78rem;
        font-weight: 850;
    }

    .invoice-summary-box strong {
        display: block;
        margin-top: 0.35rem;
        color: #182230;
        font-weight: 900;
    }

    .invoice-line-table-shell {
        overflow-x: auto;
        border: 1px solid #dfe7ec;
        border-radius: 8px;
        background: #fff;
    }

    .invoice-line-table thead th {
        border-top: 0;
        border-bottom: 1px solid #dfe7ec;
        background: #f8fbfb;
        color: #475467;
        font-size: 0.76rem;
        font-weight: 850;
        white-space: nowrap;
    }

    .invoice-line-table tbody td {
        vertical-align: middle;
        border-color: #eef2f4;
    }

    .invoice-total-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 8px;
        color: #fff;
        background: #182230;
    }

    .invoice-total-bar span {
        font-weight: 850;
    }

    .invoice-total-bar strong {
        font-size: 1.2rem;
        font-weight: 900;
    }

    @@media (max-width: 1199.98px) {
        .invoice-builder-grid,
        .invoice-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .invoice-builder-card.service-card {
            grid-column: 1 / -1;
        }
    }

    @@media (max-width: 767.98px) {
        .invoice-create-hero,
        .invoice-calc-head,
        .invoice-calc-hero {
            flex-direction: column;
            align-items: stretch;
        }

        .invoice-builder-grid,
        .invoice-date-grid,
        .invoice-service-input-grid,
        .invoice-service-list,
        .invoice-summary-grid {
            grid-template-columns: 1fr;
        }

        .invoice-calc-actions {
            flex-direction: column;
        }

        .invoice-calc-room {
            min-width: 0;
            text-align: left;
        }
    }
</style>

@section Scripts {
    <script src="~/custom/invoice/create-invoice.js" asp-append-version="true"></script>
    <script src="~/custom/invoice/calculate-invoice.js" asp-append-version="true"></script>
}
