@{
    ViewData["Title"] = "Create Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/employee.css" rel="stylesheet" asp-append-version="true" />
@section Styles {
    <link href="~/custom/employee/employee-create.css" rel="stylesheet" asp-append-version="true" />
}

<div class="container-fluid employee-page admin-redesign employee-create-page employee-create-workspace">
    <section class="employee-create-hero">
        <div>
            <div class="employee-create-kicker">Staff onboarding</div>
            <h1>Tạo nhân viên</h1>
            <p>Tạo tài khoản nội bộ, chọn vai trò bằng dropdown và lưu thông tin liên hệ trong một form gọn hơn.</p>
        </div>
        <a class="btn btn-outline-secondary employee-create-back" asp-controller="Employee" asp-action="Employees">
            <i class="fas fa-arrow-left fa-sm mr-1"></i> Quay lại danh sách
        </a>
    </section>

    <div class="employee-create-layout">
        <section class="employee-create-card employee-create-main">
            <div class="employee-create-card-header">
                <div>
                    <div class="employee-create-kicker">Thông tin hồ sơ</div>
                    <h2>Nhân viên mới</h2>
                </div>
                <div class="employee-create-step">01</div>
            </div>

            <div class="employee-create-grid">
                <div class="employee-field">
                    <label for="employeeCreateUserName">Tên đăng nhập</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-user"></i>
                        <input type="text" class="form-control" id="employeeCreateUserName" placeholder="Ví dụ: receptionist01">
                    </div>
                </div>
                <div class="employee-field">
                    <label for="employeeCreateFullName">Họ tên</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-id-card"></i>
                        <input type="text" class="form-control" id="employeeCreateFullName" placeholder="Ví dụ: Nguyễn Văn A">
                    </div>
                </div>
                <div class="employee-field">
                    <label for="employeeCreateEmail">Email</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-envelope"></i>
                        <input type="email" class="form-control" id="employeeCreateEmail" placeholder="staff@hotel.com">
                    </div>
                </div>
                <div class="employee-field">
                    <label for="employeeCreatePhoneNumber">Số điện thoại</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-phone"></i>
                        <input type="text" class="form-control" id="employeeCreatePhoneNumber" placeholder="0901234567">
                    </div>
                </div>
                <div class="employee-field">
                    <label for="employeeCreatePassword">Mật khẩu</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-lock"></i>
                        <input type="password" class="form-control" id="employeeCreatePassword" placeholder="Nhập mật khẩu">
                    </div>
                </div>
                <div class="employee-field">
                    <label for="employeeCreateRoleIds">Vai trò</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-user-shield"></i>
                        <select class="form-control employee-role-dropdown" id="employeeCreateRoleIds"></select>
                    </div>
                    <small class="form-text text-muted">Role Customer sẽ được tự loại khỏi danh sách.</small>
                </div>
                <div class="employee-field employee-wide-field">
                    <label for="employeeCreateBackgroundImage">Ảnh đại diện</label>
                    <div class="employee-input-icon">
                        <i class="fas fa-image"></i>
                        <input type="text" class="form-control" id="employeeCreateBackgroundImage" placeholder="user.png, images/user.png hoặc URL ảnh">
                    </div>
                </div>
                <div class="employee-field employee-wide-field">
                    <label for="employeeCreateAddress">Địa chỉ</label>
                    <textarea class="form-control employee-textarea" id="employeeCreateAddress" rows="3" placeholder="Địa chỉ liên hệ"></textarea>
                </div>
            </div>

            <div class="employee-create-footer">
                <div class="employee-create-note">
                    <i class="fas fa-info-circle"></i>
                    <span>API sẽ tự xác định quyền quản trị dựa trên vai trò được chọn.</span>
                </div>
                <button type="button" class="btn btn-primary employee-create-submit" id="employeeCreateSubmitButton">
                    <i class="fas fa-save fa-sm mr-1"></i> Lưu nhân viên mới
                </button>
            </div>
        </section>

        <aside class="employee-create-card employee-create-side">
            <div class="employee-avatar-shell">
                <div class="employee-avatar-circle">
                    <i class="fas fa-user-tie"></i>
                </div>
                <div>
                    <div class="employee-create-kicker">Account preview</div>
                    <h2>Sẵn sàng cấp quyền</h2>
                    <p>Chọn đúng vai trò để nhân viên mới vào hệ thống với phạm vi thao tác phù hợp.</p>
                </div>
            </div>

            <div class="employee-check-list">
                <div class="employee-check-item">
                    <i class="fas fa-check"></i>
                    <span>Tên đăng nhập và mật khẩu dùng để đăng nhập admin.</span>
                </div>
                <div class="employee-check-item">
                    <i class="fas fa-check"></i>
                    <span>Email, số điện thoại giúp nhận diện nhân sự trong danh sách.</span>
                </div>
                <div class="employee-check-item">
                    <i class="fas fa-check"></i>
                    <span>Nếu bỏ trống ảnh, hệ thống dùng ảnh mặc định.</span>
                </div>
            </div>

            <div class="employee-role-callout">
                <div class="employee-role-icon"><i class="fas fa-user-shield"></i></div>
                <div>
                    <div class="employee-role-title">Vai trò dạng dropdown</div>
                    <div class="employee-role-text">Mỗi tài khoản mới chọn một vai trò chính để tránh nhầm quyền khi tạo.</div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/custom/employee/employee-create.js" asp-append-version="true"></script>
}
