                  y2="12.9"></line>
                <polyline fill="none" stroke="#FFFFFF" stroke-width="3" stroke-miterlimit="10"
                  points="22.2,1.1 34,12.9 22.2,24.7   "></polyline>
              </g>
            </svg></span>
        </a>
      </div>
      <div class="social-links position-absolute">
        <ul class="list-unstyled d-flex d-md-block justify-content-center">
