
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .password-page {
        min-height: 100vh;
        padding: 172px 0 72px;
        background:
            linear-gradient(90deg, rgba(255,255,255,.96) 0 52%, rgba(255,247,239,.94) 52% 100%),
            radial-gradient(circle at 12% 8%, rgba(255, 122, 0, .12), transparent 34%),
            #f7f2ec;
    }

    .password-page__shell {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(320px, .92fr) minmax(0, 1.08fr);
        border: 1px solid #eadfd3;
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 24px 70px rgba(15, 23, 42, .10);
    }

    .password-page__visual {
        position: relative;
        min-height: 560px;
        padding: 34px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #fff;
        background:
            linear-gradient(145deg, rgba(14, 20, 31, .92), rgba(20, 50, 68, .82)),
            url('/images/room/room-b1.jpg') center/cover no-repeat;
    }

    .password-page__visual::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,.22) 100%);
    }

    .password-page__visual > * {
        position: relative;
        z-index: 1;
    }

    .password-page__brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .password-page__mark {
        position: relative;
        width: 54px;
        height: 54px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 54px;
        border: 1px solid rgba(255,255,255,.45);
        border-radius: 14px;
        background: rgba(255,255,255,.10);
        overflow: hidden;
    }

    .password-page__mark::before {
        content: "T";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-family: Georgia, serif;
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
        text-transform: none;
        letter-spacing: 0;
    }

    .password-page__brand strong,
    .password-page__brand span {
        display: block;
    }

    .password-page__brand strong {
        font-size: 18px;
        letter-spacing: .03em;
    }

    .password-page__brand span {
        margin-top: 2px;
        color: rgba(255,255,255,.68);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .password-page__eyebrow,
    .password-form__eyebrow {
        display: inline-block;
        color: #ff7a00;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .password-page__visual h1 {
        max-width: 440px;
        margin: 14px 0 16px;
        color: #fff;
        font-family: "Lora", serif;
        font-size: clamp(42px, 5vw, 64px);
        line-height: 1;
    }

    .password-page__visual p {
        max-width: 420px;
        margin: 0;
        color: rgba(255,255,255,.78);
        font-size: 16px;
        line-height: 1.7;
    }

    .password-page__tips {
        display: grid;
        gap: 12px;
    }

    .password-page__tip {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 14px;
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 14px;
        background: rgba(255,255,255,.09);
        backdrop-filter: blur(12px);
        color: rgba(255,255,255,.90);
        font-weight: 800;
    }

    .password-page__tip i {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 34px;
        border-radius: 12px;
        background: rgba(255,122,0,.18);
        color: #ff9a3d;
    }

    .password-page__form-area {
        padding: 44px 52px;
        display: flex;
        align-items: center;
    }

    .password-form {
        width: 100%;
    }

    .password-form__head {
        margin-bottom: 28px;
    }

    .password-form__head h2 {
        margin: 8px 0 8px;
        color: #171923;
        font-family: "Lora", serif;
        font-size: clamp(30px, 3vw, 42px);
        line-height: 1.12;
    }

    .password-form__head p {
        max-width: 560px;
        margin: 0;
        color: #667085;
        line-height: 1.6;
    }

    .password-form__grid {
        display: grid;
        gap: 16px;
    }

    .password-field label {
        display: block;
        margin-bottom: 8px;
        color: #475467;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .password-input {
        position: relative;
    }

    .password-input__lead {
        position: absolute;
        top: 50%;
        left: 17px;
        color: #ff7a00;
        transform: translateY(-50%);
    }

    .password-input input {
        width: 100%;
        height: 58px;
        padding: 0 58px 0 48px;
        border: 1px solid #e5d8ca;
        border-radius: 16px;
        background: #fffaf5;
        color: #171923;
        font-size: 15px;
        font-weight: 700;
        outline: none;
        transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
    }

    .password-input input::placeholder {
        color: #98a2b3;
        font-weight: 600;
    }

    .password-input input:focus {
        border-color: #ff7a00;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(255, 122, 0, .13);
    }

    .change-password-toggle {
        position: absolute;
        top: 50%;
        right: 14px;
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 12px;
        background: #f1ece6;
        color: #667085;
        transform: translateY(-50%);
    }

    .change-password-toggle:hover,
    .change-password-toggle:focus {
        color: #ff7a00;
        background: #fff0e3;
        outline: none;
    }

    .password-form__actions {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        margin-top: 26px;
    }

    .password-form__back,
    .password-form__submit {
        min-height: 54px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        padding: 0 22px;
        border-radius: 16px;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .password-form__back {
        border: 1px solid #e4d8cb;
        background: #fff;
        color: #475467;
    }

    .password-form__back:hover {
        color: #171923;
        border-color: #cbbbab;
    }

    .password-form__submit {
        min-width: 230px;
        border: 0;
        background: #ff7a00;
        color: #fff;
        box-shadow: 0 16px 28px rgba(255, 122, 0, .20);
    }

    .password-form__submit:hover {
        filter: brightness(.96);
    }

    .password-form__submit:disabled {
        opacity: .7;
        cursor: wait;
    }

    @@media (max-width: 991.98px) {
        .password-page__shell {
            grid-template-columns: 1fr;
        }

        .password-page__visual {
            min-height: auto;
            gap: 34px;
        }
    }

    @@media (max-width: 767.98px) {
        .password-page {
            padding: 132px 0 42px;
        }

        .password-page__visual,
        .password-page__form-area {
            padding: 26px 20px;
        }

        .password-form__actions {
            flex-direction: column-reverse;
            align-items: stretch;
        }

        .password-form__back,
        .password-form__submit {
            width: 100%;
        }
    }
</style>

<section class="password-page">
    <div class="container">
        <div class="password-page__shell">
            <aside class="password-page__visual">
                <div class="password-page__brand">
                    <span class="password-page__mark" aria-hidden="true"></span>
                    <div>
                        <strong>Telly Account</strong>
                        <span>Security center</span>
                    </div>
                </div>

                <div>
                    <span class="password-page__eyebrow">Bảo mật tài khoản</span>
                    <h1>Kiểm soát quyền truy cập của bạn.</h1>
                    <p>Đổi mật khẩu nhanh, rõ ràng và giữ phiên đăng nhập hiện tại để bạn tiếp tục thao tác.</p>
                </div>

                <div class="password-page__tips">
                    <div class="password-page__tip">
                        <i class="fa fa-lock" aria-hidden="true"></i>
                        <span>Mật khẩu mới tối thiểu 6 ký tự</span>
                    </div>
                    <div class="password-page__tip">
                        <i class="fa fa-shield" aria-hidden="true"></i>
                        <span>Thông tin được gửi qua phiên đã xác thực</span>
                    </div>
                    <div class="password-page__tip">
                        <i class="fa fa-key" aria-hidden="true"></i>
                        <span>Cần xác nhận đúng mật khẩu hiện tại</span>
                    </div>
                </div>
            </aside>

            <div class="password-page__form-area">
                <form id="changePasswordForm" class="password-form" novalidate>
                    <div class="password-form__head">
                        <span class="password-form__eyebrow">Password update</span>
                        <h2>Thiết lập mật khẩu mới</h2>
                        <p>Nhập mật khẩu hiện tại, chọn mật khẩu mới và xác nhận lại để hoàn tất cập nhật.</p>
                    </div>

                    <div class="password-form__grid">
                        <div class="password-field">
                            <label for="oldPassword">Mật khẩu hiện tại</label>
                            <div class="password-input">
                                <i class="fa fa-lock password-input__lead" aria-hidden="true"></i>
                                <input id="oldPassword" name="oldPassword" type="password" placeholder="Nhập mật khẩu hiện tại" required />
                                <button class="change-password-toggle" type="button" data-password-toggle="oldPassword" aria-label="Hiện mật khẩu hiện tại">
                                    <i class="fa fa-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <div class="password-field">
                            <label for="newPassword">Mật khẩu mới</label>
                            <div class="password-input">
                                <i class="fa fa-key password-input__lead" aria-hidden="true"></i>
                                <input id="newPassword" name="newPassword" type="password" placeholder="Tối thiểu 6 ký tự" required />
                                <button class="change-password-toggle" type="button" data-password-toggle="newPassword" aria-label="Hiện mật khẩu mới">
                                    <i class="fa fa-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <div class="password-field">
                            <label for="confirmPassword">Xác nhận mật khẩu mới</label>
                            <div class="password-input">
                                <i class="fa fa-check-circle password-input__lead" aria-hidden="true"></i>
                                <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" required />
                                <button class="change-password-toggle" type="button" data-password-toggle="confirmPassword" aria-label="Hiện xác nhận mật khẩu mới">
                                    <i class="fa fa-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="password-form__actions">
                        <a class="password-form__back" href="/Home/Index">
                            <i class="fa fa-arrow-left" aria-hidden="true"></i>
                            Trang chủ
                        </a>
                        <button id="changePasswordSubmitButton" class="password-form__submit" type="submit">
                            <i class="fa fa-refresh" aria-hidden="true"></i>
                            Cập nhật mật khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/custom/user-system/change-password.js" asp-append-version="true"></script>
}
