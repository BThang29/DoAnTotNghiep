  <section id="booking-wrap" class="padding-large">
    <div class="container">
      <div class="row">

        <form action="" class="booking-form d-flex flex-wrap align-items-center justify-content-around">
          <div class="booking-content d-flex flex-wrap col-lg-8">
            <div class="booking-item">
              <label for="date-in" class="text-uppercase d-block">Nhận phòng</label>
              <div class="date" id="select-arrival-date"></div>
            </div>
            <div class="booking-item">
              <label for="date-in" class="text-uppercase d-block">Trả phòng</label>
              <div class="date" id="select-departure-date"></div>
            </div>
            <div class="booking-item">
              <label class="text-uppercase d-block">Số phòng</label>
              <input type="number" class="booking" name="rooms" min="01" max="5" placeholder="01" value="01">
            </div>
            <div class="booking-item">
              <label class="text-uppercase d-block">Số khách</label>
              <input type="number" class="booking" name="guests" min="01" max="10" placeholder="01" value="01">
            </div>
          </div>
          <button type="button" class="btn btn-arrow btn-pill btn-medium btn-dark position-relative" data-booking-drawer-open>
            <span>Kiểm tra phòng trống<svg version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 36.1 25.8"
                enable-background="new 0 0 36.1 25.8" xml:space="preserve">
                <g>
                  <line fill="none" stroke="#FFFFFF" stroke-width="3" stroke-miterlimit="10" x1="0" y1="12.9" x2="34"
                    y2="12.9"></line>
                  <polyline fill="none" stroke="#FFFFFF" stroke-width="3" stroke-miterlimit="10"
                    points="22.2,1.1 34,12.9 22.2,24.7   "></polyline>
                </g>
              </svg></span>
          </button>
        </form>

      </div>
    </div>
  </section>

